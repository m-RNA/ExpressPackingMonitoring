<Window x:Class="ExpressPackingMonitoring.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ExpressPackingMonitoring"
        xmlns:vm="clr-namespace:ExpressPackingMonitoring.ViewModels"
        Title="📦 快递打包监控终端 v2.0" Height="850" Width="1300"
        Background="#E9ECEF" WindowState="Maximized" Closed="Window_Closed">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="20,10" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="模式: " FontSize="22" FontWeight="Bold" Foreground="#555"/>
                        <TextBlock Text="{Binding CurrentMode}" FontSize="26" FontWeight="Black" Foreground="#0078D7">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentMode}" Value="退货">
                                            <Setter Property="Foreground" Value="DarkOrange"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="当前单号: " FontSize="22" Foreground="#555"/>
                        <TextBlock Text="{Binding CurrentOrderId}" FontSize="32" FontWeight="Black" Foreground="#DC3545"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" x:Name="RecIndicator" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard Name="StartFlashing">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1.0" To="0.0" Duration="0:0:0.5" AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="StartFlashing"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Ellipse Width="24" Height="24" Fill="Red" Margin="0,0,8,0"/>
                        <TextBlock Text="REC 录制中" Foreground="Red" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>

                    <Button Grid.Column="3" Content="📼 录像回放" Command="{Binding OpenPlaybackCommand}" Focusable="False" Margin="0,0,10,0" Padding="15,8" FontSize="16" FontWeight="Bold" Background="#17A2B8" Foreground="White" Cursor="Hand"/>
                    <Button Grid.Column="4" Content="⚙ 系统设置" Click="BtnSettings_Click" Focusable="False" Padding="15,8" FontSize="16" FontWeight="Bold" Background="#6C757D" Foreground="White" Cursor="Hand"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="📦 扫码或输入单号：" VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="#333"/>

                    <TextBox x:Name="ScanInputTextBox" Grid.Column="1" Margin="10,0" FontSize="24" Padding="10,5" FontWeight="Bold" Foreground="#0078D7" Background="#F4F6F8" BorderBrush="#0078D7" BorderThickness="2" VerticalContentAlignment="Center"
                             PreviewKeyDown="ScanInputTextBox_PreviewKeyDown" LostFocus="ScanInputTextBox_LostFocus"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="▶ 开始录制" Command="{Binding StartRecordingCommand}" Focusable="False" Width="140" Background="#28A745" Foreground="White" FontSize="18" FontWeight="Bold" Padding="0,10" Margin="0,0,10,0" Cursor="Hand"/>
                        <Button Content="⏹ 停止录制" Command="{Binding StopRecordingCommand}" Focusable="False" Width="140" Background="#DC3545" Foreground="White" FontSize="18" FontWeight="Bold" Padding="0,10" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Background="Black" CornerRadius="8" ClipToBounds="True">
                <Image Source="{Binding VideoFrame}" Stretch="Uniform"/>
            </Border>

            <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="💾 磁盘占用: " VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    <ProgressBar Grid.Column="1" Margin="10,0" Height="22" Minimum="0" Maximum="100" Value="{Binding DiskUsagePercent}" Foreground="#0078D7"/>
                    <TextBlock Grid.Column="2" Text="{Binding DiskUsagePercent, StringFormat={}{0:F1}%}" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="📝 系统动态日志" FontSize="20" FontWeight="Black" Foreground="#333" Margin="0,0,0,15"/>
                <ListView Grid.Row="1" ItemsSource="{Binding HistoryLogs}" AlternationCount="2" BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="8">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="{Binding Time, StringFormat={}{0:HH:mm:ss}}" Foreground="#888" FontSize="14"/>
                                        <TextBlock Text="{Binding OrderId}" HorizontalAlignment="Right" FontWeight="Bold" Foreground="#0078D7" FontSize="14"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Status}" Margin="0,5,0,0" TextWrapping="Wrap" FontSize="14"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="IsHitTestVisible" Value="False"/>
                            <Style.Triggers>
                                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                    <Setter Property="Background" Value="#F8F9FA"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Window>