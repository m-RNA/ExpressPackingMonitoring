<Window x:Class="ExpressPackingMonitoring.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ExpressPackingMonitoring.ViewModels"
        Title="打包监控" Height="850" Width="1350"
        Background="{DynamicResource WindowBackground}" WindowState="Maximized" Closing="Window_Closing"
        Icon="app.ico"
        FontFamily="Microsoft YaHei UI, Segoe UI">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- 修复 ComboBox 稳定性问题的核心代码 -->
        <Style TargetType="ComboBoxItem">
            <!-- 手动指定对齐方式，不再让系统去 FindAncestor，从而消除报错 -->
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Gd" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}" 
                                SnapsToDevicePixels="true"
                                CornerRadius="4"
                                Margin="2,1">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- 增加悬浮效果，提升交互感 -->
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Gd" Property="Background" Value="{DynamicResource ControlBackgroundHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="Gd" Property="Background" Value="{DynamicResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 确保 ComboBox 容器本身也是稳定的 -->
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="False"/> <!-- 禁用像素级滚动有助于稳定性 -->
        </Style>

        <Style TargetType="Button" x:Key="ModernBtn">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,24,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource PanelBackground}" CornerRadius="10" Padding="20,16" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.04"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Margin="0,0,20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Command="{Binding ToggleModeCommand}" Focusable="False" Margin="0,0,16,0" Cursor="Hand" ToolTip="点击切换模式" Height="52" MinWidth="130">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16,0">
                                                            <TextBlock x:Name="ModeIcon" Text="📦 " FontSize="22" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                            <TextBlock Text="{Binding CurrentMode}" FontSize="24" FontWeight="Black" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding CurrentMode}" Value="退货">
                                                            <Setter TargetName="ModeIcon" Property="Text" Value="🔙 "/>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentMode}" Value="退货">
                                                <Setter Property="Background" Value="{DynamicResource AccentOrange}"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Grid Grid.Column="1">
                                <TextBox x:Name="ScanInputTextBox" Height="52" FontSize="22" Padding="16,0,36,0" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Background="{DynamicResource ControlBackground}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="2" VerticalContentAlignment="Center"
                                         Text="{Binding ScanInputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         GotKeyboardFocus="ScanInputTextBox_GotFocus" PreviewMouseLeftButtonDown="ScanInputTextBox_PreviewMouseLeftButtonDown"
                                         PreviewKeyDown="ScanInputTextBox_PreviewKeyDown" LostFocus="ScanInputTextBox_LostFocus">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <Button Command="{Binding ClearScanInputCommand}" Focusable="False" Content="✕" FontSize="14" Width="28" Height="28" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0" Cursor="Hand" Foreground="{DynamicResource TextMuted}" Background="Transparent" BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="14">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Grid>

                        <Button Grid.Column="1" Command="{Binding ToggleRecordingCommand}" Focusable="False" Height="52" Width="160" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModernBtn}">
                                    <Setter Property="Background" Value="{DynamicResource AccentGreen}"/>
                                    <Setter Property="Content" Value="▶ 开始录制"/>
                                    <Setter Property="FontWeight" Value="Black"/>
                                    <Setter Property="FontSize" Value="20"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentRed}"/>
                                            <Setter Property="Content" Value="⏹ 停止录制"/>
                                        </DataTrigger>
                                        <!-- 新增：Busy过渡状态，优先于 IsRecording -->
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="Background" Value="#A0A0A0"/> <!-- 灰色表示被锁定 -->
                                            <Setter Property="Content" Value="{Binding BusyText}"/> <!-- 显示正在启动/停止 -->
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="{DynamicResource VideoPlaceholder}" CornerRadius="10" ClipToBounds="True">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.04"/>
                    </Border.Effect>
                    <Grid>
                        <Image x:Name="VideoImage" Source="{Binding VideoFrame}" Stretch="Uniform"/>
                        <Rectangle x:Name="ZoomPreviewBorder"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Stroke="#FF0078D7"
                                   StrokeThickness="3"
                                   Fill="Transparent"
                                   Visibility="Collapsed"
                                   RadiusX="2" RadiusY="2">
                            <Rectangle.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="White" Opacity="0.8"/>
                            </Rectangle.Effect>
                        </Rectangle>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="{DynamicResource PanelBackground}" CornerRadius="10" Padding="20,12" Margin="0,20,0,0">
                    <Border.Effect><DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.04"/></Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="今日件数:" FontSize="15" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Bottom" Margin="0,0,8,3"/>
                            <TextBlock Text="{Binding TotalPieces}" FontSize="24" FontWeight="Black" Foreground="{DynamicResource AccentBlueDark}" Margin="0,0,24,0"/>
                            <TextBlock Text="平均时长:" FontSize="15" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Bottom" Margin="0,0,8,3"/>
                            <TextBlock Text="{Binding AveragePackTime}" FontSize="24" FontWeight="Black" Foreground="{DynamicResource AccentBlueDark}" Margin="0,0,24,0"/>
                            <TextBlock Text="总耗时:" FontSize="15" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Bottom" Margin="0,0,8,3"/>
                            <TextBlock Text="{Binding TotalPackTimeStr}" FontSize="24" FontWeight="Black" Foreground="{DynamicResource AccentBlueDark}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource ModernBtn}" Content="📊 数据" Command="{Binding OpenStatsCommand}" Background="{DynamicResource AccentPurple}" Width="120" Height="42" Margin="0,0,10,0"/>
                            <Button Style="{StaticResource ModernBtn}" Content="🎬 回放" Command="{Binding OpenPlaybackCommand}" Background="{DynamicResource AccentCyan}" Width="120" Height="42" Margin="0,0,10,0"/>
                            <Button Style="{StaticResource ModernBtn}" Content="⚙️ 设置" Click="BtnSettings_Click" Background="{DynamicResource TextSecondary}" Width="120" Height="42"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1" Background="{DynamicResource PanelBackground}" CornerRadius="10" Padding="16,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.04"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- 行1条形码: 清除/发货/退货 -->
                    <Grid Grid.Row="0" Margin="0,0,0,6" Height="60">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Barcode1Label}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" TextAlignment="Center" Width="20" LineHeight="18" Margin="0,0,4,0"/>
                        <Grid Grid.Column="1">
                            <Image Source="{Binding Barcode1Image}" Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="12,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Barcode1Image}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="条码冷却中…" FontSize="12" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <ProgressBar Height="6" Minimum="0" Maximum="100" Value="{Binding Barcode1CooldownProgress}" Foreground="{DynamicResource AccentBlue}" Background="{DynamicResource BorderStrong}" BorderThickness="0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                    <Border Grid.Row="1" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,1,0,0" Padding="0,6,0,0" Margin="0,0,0,6">
                        <TextBlock Text="扫码动态" FontSize="18" FontWeight="Black" Foreground="{DynamicResource TextPrimary}"/>
                    </Border>
                    <ListView Grid.Row="2" ItemsSource="{Binding FilteredLogs}" AlternationCount="2" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <!-- 容器 Border -->
                                <Border x:Name="ItemBorder" Background="{DynamicResource ControlBackground}" CornerRadius="6" Margin="2,2,2,6" Padding="10,8" ClipToBounds="True">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.04" Color="{DynamicResource ShadowColor}"/>
                                    </Border.Effect>
                                    
                                    <Grid>
                                        <!-- 1. 优化后的流光背景层：增加对比度，使用平移变换 -->
                                        <Rectangle x:Name="ShimmerLayer" Margin="-10,-8" Visibility="Collapsed" IsHitTestVisible="False">
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <!-- 使用相对变换来平移整个画刷 -->
                                                    <LinearGradientBrush.RelativeTransform>
                                                        <TranslateTransform x:Name="ShimmerTransform" X="-1" />
                                                    </LinearGradientBrush.RelativeTransform>
                                                    <!-- 渐变点设计：透明 -> 浅红 -> 高亮白红(核心) -> 浅红 -> 透明 -->
                                                    <GradientStop Color="Transparent" Offset="0"/>
                                                    <GradientStop Color="#10FF0000" Offset="0.3"/>
                                                    <GradientStop Color="#B0FF2222" Offset="0.5"/> <!-- 高对比度核心 -->
                                                    <GradientStop Color="#10FF0000" Offset="0.7"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>

                                        <!-- 2. 内容层 (保持不变) -->
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding OrderId}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                
                                                <!-- 状态标签 -->
                                                <Border Grid.Column="2" x:Name="BadgeBorder" CornerRadius="4" Padding="6,2" VerticalAlignment="Center" Background="{DynamicResource BadgePackBg}">
                                                    <TextBlock x:Name="BadgeText" Text="{Binding Mode}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BadgePackText}"/>
                                                </Border>
                                            </Grid>
                                            
                                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="⏱ " Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                                                <TextBlock x:Name="DurationText" Text="{Binding Duration}" FontWeight="Bold" FontSize="12" Margin="0,0,12,0" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Text="📅 " Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                                                <TextBlock Text="{Binding DateStr}" Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- 触发器部分 -->
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AccentRed}"/>
                                        <Setter TargetName="ItemBorder" Property="BorderThickness" Value="1.5"/>
                                        <Setter TargetName="BadgeBorder" Property="Background" Value="{DynamicResource BadgeErrorBg}"/>
                                        <Setter TargetName="BadgeText" Property="Foreground" Value="{DynamicResource BadgeErrorText}"/>
                                        <Setter TargetName="DurationText" Property="Foreground" Value="{DynamicResource AccentRed}"/>
                                        
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="ShimmerStoryboard">
                                                <Storyboard>
                                                    <!-- 显示流光层 -->
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ShimmerLayer" Storyboard.TargetProperty="Visibility">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                    
                                                    <!-- 核心动效：让整个画刷从左侧完全消失的位置(-1.5)滑动到右侧完全消失的位置(1.5) -->
                                                    <!-- 这种方式保证了渐变的“小尾巴”是平滑进入和出的，不会在中间拉伸 -->
                                                    <DoubleAnimation Storyboard.TargetName="ShimmerTransform" 
                                                                     Storyboard.TargetProperty="X"
                                                                     From="-1.5" To="1.5" 
                                                                     Duration="0:0:2" 
                                                                     RepeatBehavior="Forever">
                                                        <!-- 使用缓动函数，让滑动更具质感 -->
                                                        <DoubleAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseInOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="ShimmerStoryboard"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Mode}" Value="退货">
                                        <Setter TargetName="BadgeBorder" Property="Background" Value="{DynamicResource BadgeReturnBg}"/>
                                        <Setter TargetName="BadgeText" Property="Foreground" Value="{DynamicResource BadgeReturnText}"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="{TemplateBinding Background}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>

                    <!-- 行2条形码: 开录/停录 -->
                    <Border Grid.Row="3" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,1,0,0" Padding="0,6,0,0" Margin="0,6,0,0">
                        <Grid Height="60">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Barcode2Label}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" TextAlignment="Center" Width="20" LineHeight="18" Margin="0,0,4,0"/>
                            <Grid Grid.Column="1">
                                <Image Source="{Binding Barcode2Image}" Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="12,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Barcode2Image}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="条码冷却中…" FontSize="12" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <ProgressBar Height="6" Minimum="0" Maximum="100" Value="{Binding Barcode2CooldownProgress}" Foreground="{DynamicResource AccentBlue}" Background="{DynamicResource BorderStrong}" BorderThickness="0"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Background="{DynamicResource ToastBackground}" CornerRadius="8" Padding="32,16" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsToastVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding ToastMessage}" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>


