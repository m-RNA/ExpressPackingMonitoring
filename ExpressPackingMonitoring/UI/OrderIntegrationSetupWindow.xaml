<Window x:Class="ExpressPackingMonitoring.UI.OrderIntegrationSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="配置订单联动" Width="800" Height="600" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}" FontFamily="Microsoft YaHei UI, Segoe UI">
    <Grid Margin="28">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="配置订单联动" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="订单信息可以同时发送到当前电脑和多台远程录像/备份电脑" Margin="0,6,0,18" Foreground="{DynamicResource TextSecondary}"/>
            <CheckBox x:Name="LocalTargetCheckBox" Content="当前电脑接收订单信息" IsChecked="True" FontSize="15"/>
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,20,0,0">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <TextBlock Text="远程目标" FontSize="17" FontWeight="SemiBold"/>
            <DataGrid x:Name="TargetsGrid" Grid.Row="1" Margin="0,10,0,10" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="启用" Binding="{Binding Enabled}" Width="60"/>
                    <DataGridTextColumn Header="名称" Binding="{Binding DisplayName}" Width="180"/>
                    <DataGridTextColumn Header="地址（IP:端口）" Binding="{Binding Address}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <Button Content="添加目标" Width="100" Height="34" Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" Click="Add_Click"/>
                <Button Content="删除" Width="80" Height="34" Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" Click="Delete_Click"/>
                <Button Content="测试连接" Width="100" Height="34" Style="{StaticResource SecondaryButtonStyle}" Click="Test_Click"/>
                <TextBlock x:Name="TestResultText" Margin="14,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Button Content="安装或更新油猴脚本" Width="170" Height="38" HorizontalAlignment="Left" Style="{StaticResource SecondaryButtonStyle}" Click="InstallScript_Click"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Width="96" Height="38" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" IsCancel="True"/>
                <Button Content="保存配置" Width="110" Height="38" Style="{StaticResource PrimaryButtonStyle}" IsDefault="True" Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
