<Window x:Class="ExpressPackingMonitoring.UI.MobileConnectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="手机/电脑连接"
        Width="520"
        SizeToContent="Height"
        MaxHeight="760"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PanelBackground}"
        Foreground="{DynamicResource TextPrimary}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="用手机或其他电脑查看录像"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="手机或其他电脑连接同一个局域网后，扫描二维码或复制网址即可打开"
                       Margin="0,8,0,0"
                       FontSize="13"
                       LineHeight="20"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondary}"/>

            <StackPanel x:Name="ReadyPanel" Margin="0,18,0,0">
                <Border HorizontalAlignment="Center"
                        Padding="12"
                        CornerRadius="10"
                        Background="White"
                        BorderBrush="{DynamicResource BorderDefault}"
                        BorderThickness="1">
                    <Image x:Name="QrCodeImage"
                           Width="260"
                           Height="260"
                           Stretch="None"
                           SnapsToDevicePixels="True"/>
                </Border>

                <TextBlock Text="访问网址"
                           Margin="0,16,0,6"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"/>
                <TextBox x:Name="AccessUrlTextBox"
                         IsReadOnly="True"
                         TextWrapping="NoWrap"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Center"
                         Padding="10,8"/>
                <Border x:Name="SecurityNotice"
                        Margin="0,12,0,0"
                        Padding="12,9"
                        CornerRadius="7"
                        Background="#18F59E0B"
                        BorderBrush="{DynamicResource AccentOrange}"
                        BorderThickness="1"
                        Visibility="Collapsed">
                    <TextBlock Text="此网址包含录像访问密钥，请不要发送给无关人员"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}"/>
                </Border>
            </StackPanel>

            <Border x:Name="UnavailablePanel"
                    Margin="0,18,0,0"
                    Padding="16"
                    CornerRadius="8"
                    Background="{DynamicResource ControlBackground}"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="1"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="暂时无法生成二维码"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock x:Name="UnavailableText"
                               Margin="0,7,0,0"
                               FontSize="13"
                               LineHeight="20"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,22,0,0">
            <Button x:Name="OpenSettingsButton"
                    Content="打开设置"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,10,0"
                    Visibility="Collapsed"
                    Click="OpenSettings_Click"/>
            <Button x:Name="CopyButton"
                    Content="复制网址"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,10,0"
                    Click="Copy_Click"/>
            <Button x:Name="OpenButton"
                    Content="电脑打开"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="0,0,10,0"
                    Click="Open_Click"/>
            <Button Content="关闭"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
