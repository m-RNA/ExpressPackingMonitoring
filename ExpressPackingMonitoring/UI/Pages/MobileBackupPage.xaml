<UserControl x:Class="ExpressPackingMonitoring.UI.Pages.MobileBackupPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28" MaxWidth="1180" HorizontalAlignment="Stretch">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="手机备份" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="手机独立录像，电脑负责接收、校验并统一保存到录像库" Margin="0,6,0,0" Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="重新运行向导" Height="38" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Focusable="False" Click="Setup_Click"/>
                    <Button Content="{Binding ToggleText}" Height="38" Style="{StaticResource SecondaryButtonStyle}" Focusable="False" Command="{Binding ToggleEnabledCommand}"/>
                </StackPanel>
            </Grid>

            <WrapPanel Margin="0,22,0,0">
                <Border Width="430" MinHeight="360" Margin="0,0,16,16" Padding="22" CornerRadius="12" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="连接这台电脑" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                            <Border HorizontalAlignment="Right" Padding="9,4" CornerRadius="10" Background="{DynamicResource BadgePackBg}">
                                <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource BadgePackText}" FontSize="12"/>
                            </Border>
                        </Grid>
                        <Border Width="220" Height="220" Margin="0,16,0,12" HorizontalAlignment="Center" Padding="8" CornerRadius="10" Background="White" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1">
                            <Grid>
                                <Image Source="{Binding QrCode}" Width="204" Height="204" Stretch="Uniform"/>
                                <TextBlock Text="二维码暂不可用" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#666666">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers><DataTrigger Binding="{Binding IsConnectionReady}" Value="False"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                        <TextBox Text="{Binding AccessUrl, Mode=OneWay}" IsReadOnly="True" Padding="10,7" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto"/>
                        <TextBlock Text="{Binding ConnectionMessage}" Margin="0,9,0,0" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}"/>
                        <WrapPanel Margin="0,14,0,0">
                            <Button Content="复制网址" Height="36" Margin="0,0,8,8" Style="{StaticResource PrimaryButtonStyle}" Focusable="False" Click="Copy_Click"/>
                            <Button Content="电脑打开" Height="36" Margin="0,0,8,8" Style="{StaticResource SecondaryButtonStyle}" Focusable="False" Click="Open_Click"/>
                            <Button Content="下载手机版" Height="36" Margin="0,0,8,8" Style="{StaticResource SecondaryButtonStyle}" Focusable="False" Click="Download_Click"/>
                            <Button Content="局域网设置" Height="36" Margin="0,0,0,8" Style="{StaticResource SecondaryButtonStyle}" Focusable="False" Click="Settings_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <StackPanel Width="500">
                    <Border Margin="0,0,0,16" Padding="20" CornerRadius="12" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="手机设备" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="{Binding DeviceSummary}" HorizontalAlignment="Right" Foreground="{DynamicResource AccentGreen}"/>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding ConnectedDevices}" Margin="0,12,0,0">
                                <ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" Margin="0,4" Foreground="{DynamicResource TextSecondary}"/></DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="手机 APP 连接后将在这里显示设备名称" Margin="0,10,0,0" Foreground="{DynamicResource TextMuted}"/>
                        </StackPanel>
                    </Border>

                    <Border Padding="20" CornerRadius="12" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="上传与校验" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="{Binding UploadSummary}" HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondary}"/>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding Uploads}" Margin="0,12,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8" Padding="12" CornerRadius="8" Background="{DynamicResource ControlBackground}">
                                            <StackPanel>
                                                <Grid>
                                                    <TextBlock Text="{Binding DisplayId}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock Text="{Binding Status}" HorizontalAlignment="Right" Foreground="{DynamicResource AccentBlue}"/>
                                                </Grid>
                                                <ProgressBar Height="6" Margin="0,8,0,6" Minimum="0" Maximum="100" Value="{Binding ProgressPercent}"/>
                                                <Grid><TextBlock Text="{Binding SizeText}" Foreground="{DynamicResource TextMuted}"/><TextBlock Text="{Binding UpdatedAtText}" HorizontalAlignment="Right" Foreground="{DynamicResource TextMuted}"/></Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </WrapPanel>

            <Border Padding="20" CornerRadius="12" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="最近手机录像" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                        <Button Content="进入录像库" HorizontalAlignment="Right" Height="34" Style="{StaticResource SecondaryButtonStyle}" Focusable="False" Click="VideoLibrary_Click"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding RecentVideos}" Margin="0,12,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,6">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding TrackingNumber}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding DeviceName}" Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding StartedAtText}" Foreground="{DynamicResource TextMuted}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding VerificationText}" Foreground="{DynamicResource AccentGreen}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding OperationMessage}" Margin="0,10,0,0" Foreground="{DynamicResource AccentBlue}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
