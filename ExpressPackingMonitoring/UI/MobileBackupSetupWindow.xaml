<Window x:Class="ExpressPackingMonitoring.UI.MobileBackupSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="配置手机备份" Width="720" Height="700" MinHeight="560" WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource WindowBackground}" FontFamily="Microsoft YaHei UI, Segoe UI">
    <Grid Margin="28">
        <Grid.RowDefinitions><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="配置手机备份" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="手机录像和电脑录像可以同时使用，都会进入同一个录像库" Margin="0,6,0,22" Foreground="{DynamicResource TextSecondary}"/>
                <Border Padding="18" CornerRadius="10" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="1  备份存储" FontSize="17" FontWeight="SemiBold"/>
                        <TextBlock x:Name="StorageText" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,12,0,0" Padding="18" CornerRadius="10" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="2  局域网连接" FontSize="17" FontWeight="SemiBold"/>
                        <TextBlock x:Name="LanText" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}"/>
                        <Border x:Name="QrPanel" Width="196" Height="196" Margin="0,12,0,8" Padding="8" HorizontalAlignment="Left" CornerRadius="10" Background="White" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1">
                            <Grid>
                                <Image x:Name="QrCodeImage" Stretch="Uniform"/>
                                <TextBlock x:Name="QrUnavailableText" Text="二维码暂不可用" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#666666"/>
                            </Grid>
                        </Border>
                        <TextBox x:Name="AccessUrlTextBox" IsReadOnly="True" Padding="10,7" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,12,0,0" Padding="18" CornerRadius="10" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="3  安装手机版" FontSize="17" FontWeight="SemiBold"/>
                        <TextBlock Text="APK 不包含在电脑版安装包中。安装后点击“连接电脑”并扫描上面的二维码，录像完成后会自动加入备份队列。" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}"/>
                        <Button Content="打开网盘下载" Width="140" Height="36" Margin="0,12,0,0" HorizontalAlignment="Left" Style="{StaticResource SecondaryButtonStyle}" Click="Download_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="取消" Width="96" Height="38" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" IsCancel="True"/>
            <Button Content="完成配置" Width="120" Height="38" Style="{StaticResource PrimaryButtonStyle}" IsDefault="True" Click="Finish_Click"/>
        </StackPanel>
    </Grid>
</Window>
