<Window x:Class="ExpressPackingMonitoring.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:localization="clr-namespace:ExpressPackingMonitoring.Localization"
        xmlns:vm="clr-namespace:ExpressPackingMonitoring.ViewModels"
        Title="打包监控" Height="850" Width="1350"
        Background="{DynamicResource WindowBackground}" WindowState="Maximized" Closing="Window_Closing"
        Icon="/app.ico"
        FontFamily="Microsoft YaHei UI, Segoe UI">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <localization:LocalizedTextConverter x:Key="LocalizedTextConverter"/>
        <!-- 修复 ComboBox 稳定性问题的核心代码 -->
        <Style TargetType="ComboBoxItem">
            <!-- 手动指定对齐方式，不再让系统去 FindAncestor，从而消除报错 -->
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Gd" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}" 
                                SnapsToDevicePixels="true"
                                CornerRadius="4"
                                Margin="2,1">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- 增加悬浮效果，提升交互感 -->
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Gd" Property="Background" Value="{DynamicResource ControlBackgroundHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="Gd" Property="Background" Value="{DynamicResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 确保 ComboBox 容器本身也是稳定的 -->
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="False"/> <!-- 禁用像素级滚动有助于稳定性 -->
        </Style>

        <Style TargetType="Button" x:Key="ModernBtn">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,24,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource PanelBackground}" CornerRadius="10" Padding="20,16" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Margin="0,0,20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Command="{Binding ToggleModeCommand}" Focusable="False" Margin="0,0,16,0" Cursor="Hand" ToolTip="点击切换模式" Height="52" MinWidth="130">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16,0">
                                                            <Path x:Name="ModeIcon" Data="{StaticResource FluentBoxIcon}" Width="22" Height="22" Stretch="Uniform" Fill="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                            <TextBlock Text="{Binding CurrentMode, Converter={StaticResource LocalizedTextConverter}}" FontSize="24" FontWeight="Black" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding CurrentMode}" Value="退货">
                                                            <Setter TargetName="ModeIcon" Property="Data" Value="{StaticResource FluentReturnIcon}"/>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentMode}" Value="退货">
                                                <Setter Property="Background" Value="{DynamicResource AccentOrange}"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Grid Grid.Column="1">
                                <TextBox x:Name="ScanInputTextBox" Height="52" FontSize="22" Padding="16,0,36,0" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Background="{DynamicResource ControlBackground}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="2" VerticalContentAlignment="Center"
                                         Text="{Binding ScanInputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         GotKeyboardFocus="ScanInputTextBox_GotFocus" PreviewMouseLeftButtonDown="ScanInputTextBox_PreviewMouseLeftButtonDown"
                                         PreviewKeyDown="ScanInputTextBox_PreviewKeyDown" TextChanged="ScanInputTextBox_TextChanged" LostFocus="ScanInputTextBox_LostFocus">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <Button Command="{Binding ClearScanInputCommand}" Focusable="False" Width="28" Height="28" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0" Cursor="Hand" Foreground="{DynamicResource TextMuted}" Background="Transparent" BorderThickness="0">
                                    <Path Data="{StaticResource FluentDismissIcon}" Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource TextMuted}"/>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="14">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Grid>

                        <Button Grid.Column="1" Command="{Binding ToggleRecordingCommand}" Focusable="False" Height="52" Width="160" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModernBtn}">
                                    <Setter Property="Background" Value="{DynamicResource AccentGreen}"/>
                                    <Setter Property="FontWeight" Value="Black"/>
                                    <Setter Property="FontSize" Value="20"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Path x:Name="RecordActionIcon" Data="{StaticResource FluentRecordIcon}" Width="20" Height="20" Stretch="Uniform" Fill="White" Margin="0,0,8,0"/>
                                                        <TextBlock x:Name="RecordActionText" Text="{x:Static localization:AppLanguage.StartRecordingText}" Foreground="White" FontWeight="{TemplateBinding FontWeight}" FontSize="{TemplateBinding FontSize}"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                                        <Setter TargetName="RecordActionIcon" Property="Data" Value="{StaticResource FluentStopIcon}"/>
                                                        <Setter TargetName="RecordActionText" Property="Text" Value="{x:Static localization:AppLanguage.StopRecordingText}"/>
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsBusy}" Value="True"/>
                                                            <Condition Binding="{Binding IsShutdownInProgress}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter TargetName="RecordActionIcon" Property="Data" Value="{StaticResource FluentArrowSyncIcon}"/>
                                                        <Setter TargetName="RecordActionText" Property="Text" Value="{Binding BusyText}"/>
                                                    </MultiDataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentRed}"/>
                                        </DataTrigger>
                                        <!-- 新增：Busy过渡状态，优先于 IsRecording -->
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsBusy}" Value="True"/>
                                                <Condition Binding="{Binding IsShutdownInProgress}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="#A0A0A0"/> <!-- 灰色表示被锁定 -->
                                        </MultiDataTrigger>
                                        <DataTrigger Binding="{Binding IsShutdownInProgress}" Value="True">
                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                            <Setter Property="Opacity" Value="0.65"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="{DynamicResource VideoPlaceholder}" CornerRadius="10" ClipToBounds="True">
                    <Grid>
                        <Image x:Name="VideoImage" Source="{Binding VideoFrame}" Stretch="Uniform"/>
                        <Rectangle x:Name="ZoomPreviewBorder"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Stroke="#990078D7"
                                   StrokeThickness="3"
                                   StrokeDashArray="4 2"
                                   Fill="Transparent"
                                   Visibility="Collapsed"
                                   Opacity="1"
                                   RadiusX="2" RadiusY="2"/>
                        <Grid x:Name="CameraBarcodeGuide"
                              Width="0"
                              Height="0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              IsHitTestVisible="False">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCameraBarcodeRecognitionEnabled}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsCameraSleeping}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Rectangle RadiusX="6" RadiusY="6" StrokeThickness="3" StrokeDashArray="6 3">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Stroke" Value="#CC0078D7"/>
                                        <Setter Property="Fill" Value="#080078D7"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCameraBarcodeCandidate}" Value="True">
                                                <Setter Property="Stroke" Value="#FFFFA000"/>
                                                <Setter Property="Fill" Value="#10FFA000"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsCameraBarcodeConfirmed}" Value="True">
                                                <Setter Property="Stroke" Value="#FF22A65A"/>
                                                <Setter Property="Fill" Value="#1822A65A"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                            <Border HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    Margin="0,10,0,0"
                                    Padding="12,6"
                                    CornerRadius="6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#CC0067B8"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCameraBarcodeCandidate}" Value="True">
                                                <Setter Property="Background" Value="#DDC47A00"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsCameraBarcodeConfirmed}" Value="True">
                                                <Setter Property="Background" Value="#DD188447"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding CameraBarcodeStatusText}"
                                           Foreground="White"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                        <!-- 摄像头休眠提示 -->
                        <Grid IsHitTestVisible="False">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCameraSleeping}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Border Background="#DD1a1a2e" CornerRadius="10"/>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path Data="{StaticResource FluentSleepIcon}" Width="52" Height="52" Stretch="Uniform" Fill="#AAFFFFFF" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <TextBlock Text="摄像头已休眠" FontSize="22" FontWeight="Bold" Foreground="#AAFFFFFF" HorizontalAlignment="Center"/>
                                <TextBlock Text="点击任意位置唤醒，再将面单放入识别框" FontSize="14" Foreground="#88FFFFFF" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="{DynamicResource PanelBackground}" CornerRadius="10" Padding="20,12" Margin="0,20,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="今日:" FontSize="15" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Bottom" Margin="0,0,8,3"/>
                            <TextBlock FontSize="24" FontWeight="Black" Foreground="{DynamicResource AccentBlueDark}" Margin="0,0,24,0">
                                <Run Text="{Binding TotalPieces, Mode=OneWay}"/><Run Text="件" FontSize="15"/>
                            </TextBlock>
                            <TextBlock Text="平均:" FontSize="15" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Bottom" Margin="0,0,8,3"/>
                            <TextBlock FontSize="24" FontWeight="Black" Foreground="{DynamicResource AccentBlueDark}" Margin="0,0,24,0">
                                <Run Text="{Binding AveragePackTimeDisplay.HourValue, Mode=OneWay}"/><Run Text="{Binding AveragePackTimeDisplay.HourUnit, Mode=OneWay}" FontSize="15"/>
                                <Run Text="{Binding AveragePackTimeDisplay.MinuteValue, Mode=OneWay}"/><Run Text="{Binding AveragePackTimeDisplay.MinuteUnit, Mode=OneWay}" FontSize="15"/>
                                <Run Text="{Binding AveragePackTimeDisplay.SecondValue, Mode=OneWay}"/><Run Text="{Binding AveragePackTimeDisplay.SecondUnit, Mode=OneWay}" FontSize="15"/>
                            </TextBlock>
                            <TextBlock Text="总耗时:" FontSize="15" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Bottom" Margin="0,0,8,3"/>
                            <TextBlock FontSize="24" FontWeight="Black" Foreground="{DynamicResource AccentBlueDark}">
                                <Run Text="{Binding TotalPackTimeDisplay.HourValue, Mode=OneWay}"/><Run Text="{Binding TotalPackTimeDisplay.HourUnit, Mode=OneWay}" FontSize="15"/>
                                <Run Text="{Binding TotalPackTimeDisplay.MinuteValue, Mode=OneWay}"/><Run Text="{Binding TotalPackTimeDisplay.MinuteUnit, Mode=OneWay}" FontSize="15"/>
                                <Run Text="{Binding TotalPackTimeDisplay.SecondValue, Mode=OneWay}"/><Run Text="{Binding TotalPackTimeDisplay.SecondUnit, Mode=OneWay}" FontSize="15"/>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource ModernBtn}" Command="{Binding OpenStatsCommand}" Background="{DynamicResource ControlBackgroundHover}" BorderBrush="{DynamicResource BorderStrong}" BorderThickness="2" Width="120" Height="42" Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource FluentDataIcon}" Width="18" Height="18" Stretch="Uniform" Fill="{DynamicResource AccentBlue}" Margin="0,0,7,0"/>
                                    <TextBlock Text="数据" Foreground="{DynamicResource TextPrimary}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ModernBtn}" Command="{Binding OpenPlaybackCommand}" Background="{DynamicResource ControlBackgroundHover}" BorderBrush="{DynamicResource BorderStrong}" BorderThickness="2" Width="120" Height="42" Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource FluentVideoIcon}" Width="18" Height="18" Stretch="Uniform" Fill="{DynamicResource AccentBlue}" Margin="0,0,7,0"/>
                                    <TextBlock Text="回放" Foreground="{DynamicResource TextPrimary}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ModernBtn}" Click="BtnSettings_Click" Background="{DynamicResource ControlBackgroundHover}" BorderBrush="{DynamicResource BorderStrong}" BorderThickness="2" Width="120" Height="42">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource FluentSettingsIcon}" Width="18" Height="18" Stretch="Uniform" Fill="{DynamicResource TextSecondary}" Margin="0,0,7,0"/>
                                    <TextBlock Text="设置" Foreground="{DynamicResource TextPrimary}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1" Background="{DynamicResource PanelBackground}" CornerRadius="10" Padding="16,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- 行1条形码: 清除/发货/退货 -->
                    <Grid Grid.Row="0" Margin="0,0,0,6" Height="60">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Barcode1Label}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" TextAlignment="Center" Width="20" LineHeight="18" Margin="0,0,4,0"/>
                        <Grid Grid.Column="1">
                            <Image Source="{Binding Barcode1Image}" Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="12,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Barcode1Image}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="条码冷却中…" FontSize="12" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <ProgressBar Height="6" Minimum="0" Maximum="100" Value="{Binding Barcode1CooldownProgress}" Foreground="{DynamicResource AccentBlue}" Background="{DynamicResource BorderStrong}" BorderThickness="0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                    <Border Grid.Row="1" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,1,0,0" Padding="0,6,0,0" Margin="0,0,0,6">
                        <TextBlock Text="扫码动态" FontSize="18" FontWeight="Black" Foreground="{DynamicResource TextPrimary}"/>
                    </Border>
                    <ListView Grid.Row="2" ItemsSource="{Binding FilteredLogs}" AlternationCount="2" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <!-- 容器 Border -->
                                <Border x:Name="ItemBorder" Background="{DynamicResource ControlBackground}" CornerRadius="6" Margin="2,2,2,6" Padding="10,8" ClipToBounds="True">
                                    
                                    <Grid>
                                        <!-- 1. 优化后的流光背景层：增加对比度，使用平移变换 -->
                                        <Rectangle x:Name="ShimmerLayer" Margin="-10,-8" Visibility="Collapsed" IsHitTestVisible="False">
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <!-- 使用相对变换来平移整个画刷 -->
                                                    <LinearGradientBrush.RelativeTransform>
                                                        <TranslateTransform x:Name="ShimmerTransform" X="-1" />
                                                    </LinearGradientBrush.RelativeTransform>
                                                    <!-- 渐变点设计：透明 -> 浅红 -> 高亮白红(核心) -> 浅红 -> 透明 -->
                                                    <GradientStop Color="Transparent" Offset="0"/>
                                                    <GradientStop Color="#10FF0000" Offset="0.3"/>
                                                    <GradientStop Color="#B0FF2222" Offset="0.5"/> <!-- 高对比度核心 -->
                                                    <GradientStop Color="#10FF0000" Offset="0.7"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>

                                        <!-- 2. 内容层 (保持不变) -->
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding OrderId}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" x:Name="ActiveStatusBorder" Background="{DynamicResource BadgeErrorBg}" CornerRadius="4" Padding="6,2" Margin="8,0" Visibility="Collapsed">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Ellipse Width="6" Height="6" Fill="{DynamicResource AccentRed}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="录制中" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BadgeErrorText}"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="2" x:Name="BadgeBorder" CornerRadius="4" Padding="6,2" VerticalAlignment="Center" Background="{DynamicResource BadgePackBg}">
                                                    <TextBlock x:Name="BadgeText" Text="{Binding Mode, Converter={StaticResource LocalizedTextConverter}}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BadgePackText}"/>
                                                </Border>
                                            </Grid>

                                            <Grid Grid.Row="1" Margin="0,5,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                                                    <Path Data="{StaticResource FluentClockIcon}" Width="12" Height="12" Stretch="Uniform" Fill="{DynamicResource TextMuted}" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding DateStr}" Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Path x:Name="DurationIcon" Data="{StaticResource FluentSaveIcon}" Width="12" Height="12" Stretch="Uniform" Fill="{DynamicResource TextMuted}" Margin="0,0,4,0"/>
                                                    <TextBlock x:Name="DurationText" Text="{Binding Duration, Converter={StaticResource LocalizedTextConverter}}" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- 触发器部分 -->
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AccentRed}"/>
                                        <Setter TargetName="ItemBorder" Property="BorderThickness" Value="1.5"/>
                                        <Setter TargetName="BadgeBorder" Property="Background" Value="{DynamicResource BadgeErrorBg}"/>
                                        <Setter TargetName="BadgeText" Property="Foreground" Value="{DynamicResource BadgeErrorText}"/>
                                        <Setter TargetName="DurationText" Property="Foreground" Value="{DynamicResource AccentRed}"/>
                                        <Setter TargetName="DurationIcon" Property="Data" Value="{StaticResource FluentClockIcon}"/>
                                        <Setter TargetName="DurationIcon" Property="Fill" Value="{DynamicResource AccentRed}"/>
                                        <Setter TargetName="ActiveStatusBorder" Property="Visibility" Value="Visible"/>
                                        
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="ShimmerStoryboard">
                                                <Storyboard>
                                                    <!-- 显示流光层 -->
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ShimmerLayer" Storyboard.TargetProperty="Visibility">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                    
                                                    <!-- 核心动效：让整个画刷从左侧完全消失的位置(-1.5)滑动到右侧完全消失的位置(1.5) -->
                                                    <!-- 这种方式保证了渐变的“小尾巴”是平滑进入和出的，不会在中间拉伸 -->
                                                    <DoubleAnimation Storyboard.TargetName="ShimmerTransform" 
                                                                     Storyboard.TargetProperty="X"
                                                                     From="-1.5" To="1.5" 
                                                                     Duration="0:0:2" 
                                                                     RepeatBehavior="Forever">
                                                        <!-- 使用缓动函数，让滑动更具质感 -->
                                                        <DoubleAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseInOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="ShimmerStoryboard"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Mode}" Value="退货">
                                        <Setter TargetName="BadgeBorder" Property="Background" Value="{DynamicResource BadgeReturnBg}"/>
                                        <Setter TargetName="BadgeText" Property="Foreground" Value="{DynamicResource BadgeReturnText}"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="{TemplateBinding Background}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>

                    <Border Grid.Row="3"
                            Background="{DynamicResource ControlBackground}"
                            BorderBrush="{DynamicResource BorderDefault}"
                            BorderThickness="1"
                            CornerRadius="7"
                            Padding="10,7"
                            Margin="0,6,0,0"
                            ToolTip="{Binding WorkstationStatusToolTip}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding WorkstationAccessText}" Foreground="{DynamicResource TextSecondary}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding WorkstationPrintStatusText}" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Button x:Name="BtnSwitchWorkstation" Grid.Column="1" Width="26" Height="28" Margin="2,0,0,0" Background="#01000000" BorderThickness="0" ToolTip="切换工位" Cursor="Hand" Focusable="False">
                                <Path Data="{StaticResource FluentArrowSwapIcon}" Width="15" Height="15" Stretch="Uniform" Fill="{DynamicResource TextSecondary}" IsHitTestVisible="False"/>
                            </Button>
                            <Button x:Name="BtnCopyMonitorAddress" Grid.Column="2" Width="26" Height="28" Margin="6,0,0,0" Background="#01000000" BorderThickness="0" ToolTip="打开网页并复制地址" Cursor="Hand" Focusable="False">
                                <Path Data="{StaticResource FluentOpenIcon}" Width="15" Height="15" Stretch="Uniform" Fill="{DynamicResource TextSecondary}" IsHitTestVisible="False"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- 行2条形码: 开录/停录 -->
                    <Border Grid.Row="4" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,1,0,0" Padding="0,6,0,0" Margin="0,6,0,0">
                        <Grid Height="60">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Barcode2Label}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" TextAlignment="Center" Width="20" LineHeight="18" Margin="0,0,4,0"/>
                            <Grid Grid.Column="1">
                                <Image Source="{Binding Barcode2Image}" Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="12,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Barcode2Image}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="条码冷却中…" FontSize="12" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <ProgressBar Height="6" Minimum="0" Maximum="100" Value="{Binding Barcode2CooldownProgress}" Foreground="{DynamicResource AccentBlue}" Background="{DynamicResource BorderStrong}" BorderThickness="0"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Background="{DynamicResource ToastBackground}" CornerRadius="8" Padding="32,16" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" Panel.ZIndex="1000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsToastVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding ToastMessage}" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>


