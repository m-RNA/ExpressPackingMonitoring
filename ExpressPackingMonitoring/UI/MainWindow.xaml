<Window x:Class="ExpressPackingMonitoring.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:localization="clr-namespace:ExpressPackingMonitoring.Localization"
        Title="打包监控" Height="850" Width="1350"
        Background="{DynamicResource WindowBackground}" WindowState="Maximized" MinWidth="760" MinHeight="680" Closing="Window_Closing" SizeChanged="Window_SizeChanged"
        Icon="/app.ico"
        FontFamily="Microsoft YaHei UI, Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="NavigationColumn" Width="224"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="16,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel x:Name="ShellBrandPanel" Margin="8,0,8,24">
                    <TextBlock Text="打包监控" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock x:Name="ShellBrandSubtitle" Text="录像 · 备份 · 订单" Margin="0,5,0,0" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                </StackPanel>
                <StackPanel Grid.Row="1">
                    <Button x:Name="NavOverview" Content="统计" Tag="overview" Height="44" Margin="0,0,0,6" HorizontalContentAlignment="Left" Padding="16,0" Focusable="False" Click="NavigationButton_Click"/>
                    <Button x:Name="NavPcRecording" Content="电脑录像" Tag="pc-recording" Height="44" Margin="0,0,0,6" HorizontalContentAlignment="Left" Padding="16,0" Focusable="False" Click="NavigationButton_Click"/>
                    <Button x:Name="NavMobileBackup" Content="手机备份" Tag="mobile-backup" Height="44" Margin="0,0,0,6" HorizontalContentAlignment="Left" Padding="16,0" Focusable="False" Click="NavigationButton_Click"/>
                    <Button x:Name="NavOrderIntegration" Content="订单联动" Tag="order-integration" Height="44" Margin="0,0,0,6" HorizontalContentAlignment="Left" Padding="16,0" Focusable="False" Click="NavigationButton_Click"/>
                    <Button x:Name="NavVideoLibrary" Content="录像库" Tag="video-library" Height="44" Margin="0,0,0,6" HorizontalContentAlignment="Left" Padding="16,0" Focusable="False" Click="NavigationButton_Click"/>
                    <Button x:Name="NavSettings" Content="设置" Tag="settings" Height="44" HorizontalContentAlignment="Left" Padding="16,0" Focusable="False" Click="NavigationButton_Click"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Margin="0,18,0,0">
                    <TextBlock Text="今日概览" Margin="8,0,8,8" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}"/>
                    <UniformGrid Columns="2">
                        <Border Margin="0,0,3,0" Padding="8,9" CornerRadius="8" Background="{DynamicResource ControlBackground}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="电脑录制" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                <TextBlock Text="{Binding TodayPcCountText}" Margin="0,4,0,0" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                        </Border>
                        <Border Margin="3,0,0,0" Padding="8,9" CornerRadius="8" Background="{DynamicResource ControlBackground}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="电脑均时" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                <TextBlock Text="{Binding AveragePackTimeCompactText}" Margin="0,4,0,0" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                    <Border Margin="0,6,0,0" Padding="9,7" CornerRadius="7" Background="{DynamicResource ControlBackground}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="今日备份手机" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                            <TextBlock Grid.Column="1" Text="{Binding MobileBackup.TodayVideoCountText, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                        </Grid>
                    </Border>
                </StackPanel>
                <Border Grid.Row="4" Margin="0,18,0,0" Padding="8,10,8,0" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <TextBlock Text="连接状态" Margin="0,0,0,8" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="局域网地址" FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                        <TextBlock Text="{Binding MonitorAccessAddressDisplay}" ToolTip="{Binding MonitorAccessAddressDisplay}" Margin="0,2,0,7" FontSize="11" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="手机设备" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                            <TextBlock Grid.Column="1" Text="{Binding MobileBackup.ConnectedMobileDeviceCountText, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="11" Foreground="{DynamicResource TextPrimary}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="订单联动" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                            <TextBlock Grid.Column="1" Text="{Binding OrderIntegration.StatusText, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="11" Foreground="{DynamicResource TextPrimary}"/>
                        </Grid>
                        <TextBlock Text="{Binding WorkstationPrintStatusText}" ToolTip="{Binding WorkstationPrintStatusText}" Margin="0,0,0,6" FontSize="11" Foreground="{DynamicResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="ShellVersionText" FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
        <Grid x:Name="PcRecordingModule" Visibility="Collapsed">
            <ContentControl x:Name="PcRecordingContentHost"/>
        </Grid>

        <ScrollViewer x:Name="OverviewModule" VerticalScrollBarVisibility="Auto">
            <ContentControl x:Name="OverviewStatisticsContentHost"/>
        </ScrollViewer>

        <Grid x:Name="MobileBackupModule" Visibility="Collapsed">
            <ContentControl x:Name="MobileBackupContentHost"/>
        </Grid>

        <Grid x:Name="OrderIntegrationModule" Visibility="Collapsed">
            <ContentControl x:Name="OrderIntegrationContentHost"/>
        </Grid>

        <Grid x:Name="VideoLibraryModule" Visibility="Collapsed">
            <ContentControl x:Name="VideoLibraryContentHost"/>
        </Grid>

        <Grid x:Name="SettingsModule" Visibility="Collapsed">
            <ContentControl x:Name="SettingsContentHost"/>
        </Grid>
        </Grid>

        <Border Grid.ColumnSpan="2" Background="{DynamicResource ToastBackground}" CornerRadius="8" Padding="32,16" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" Panel.ZIndex="1000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsToastVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding ToastMessage}" Foreground="{StaticResource TextOnAccent}" FontSize="18" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>


