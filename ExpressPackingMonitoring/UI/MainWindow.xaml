<Window x:Class="ExpressPackingMonitoring.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:localization="clr-namespace:ExpressPackingMonitoring.Localization"
        Title="打包监控" Height="850" Width="1350"
        Background="{DynamicResource WindowBackground}" WindowState="Maximized" MinWidth="760" MinHeight="520" Closing="Window_Closing" SizeChanged="Window_SizeChanged"
        Icon="/app.ico"
        FontFamily="Microsoft YaHei UI, Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="NavigationColumn" Width="224"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="16,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel x:Name="ShellBrandPanel" Margin="8,0,8,24">
                    <TextBlock Text="打包监控" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock x:Name="ShellBrandSubtitle" Text="录像 · 备份 · 订单" Margin="0,5,0,0" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                </StackPanel>
                <StackPanel Grid.Row="1">
                    <Button x:Name="NavOverview" Content="概览" Tag="overview" Height="44" Margin="0,0,0,6" HorizontalContentAlignment="Left" Padding="16,0" Focusable="False" Click="NavigationButton_Click"/>
                    <Button x:Name="NavPcRecording" Content="电脑录像" Tag="pc-recording" Height="44" Margin="0,0,0,6" HorizontalContentAlignment="Left" Padding="16,0" Focusable="False" Click="NavigationButton_Click"/>
                    <Button x:Name="NavMobileBackup" Content="手机备份" Tag="mobile-backup" Height="44" Margin="0,0,0,6" HorizontalContentAlignment="Left" Padding="16,0" Focusable="False" Click="NavigationButton_Click"/>
                    <Button x:Name="NavOrderIntegration" Content="订单联动" Tag="order-integration" Height="44" Margin="0,0,0,6" HorizontalContentAlignment="Left" Padding="16,0" Focusable="False" Click="NavigationButton_Click"/>
                    <Button x:Name="NavVideoLibrary" Content="录像库" Tag="video-library" Height="44" Margin="0,0,0,6" HorizontalContentAlignment="Left" Padding="16,0" Focusable="False" Click="NavigationButton_Click"/>
                    <Button x:Name="NavSettings" Content="设置" Tag="settings" Height="44" HorizontalContentAlignment="Left" Padding="16,0" Focusable="False" Click="NavigationButton_Click"/>
                </StackPanel>
                <StackPanel Grid.Row="3" Margin="8,18,8,0">
                    <TextBlock x:Name="ShellLanStatusText" Text="局域网服务准备中" FontSize="12" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                    <TextBlock x:Name="ShellVersionText" Margin="0,6,0,0" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
        <Grid x:Name="PcRecordingModule" Visibility="Collapsed">
            <ContentControl x:Name="PcRecordingContentHost"/>
        </Grid>

        <ScrollViewer x:Name="OverviewModule" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32" MaxWidth="1120" HorizontalAlignment="Stretch">
                <TextBlock Text="概览" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="电脑录像、手机备份和订单联动可以同时使用" Margin="0,6,0,24" FontSize="14" Foreground="{DynamicResource TextSecondary}"/>
                <UniformGrid x:Name="OverviewCardsGrid" Columns="3">
                    <Border Margin="0,0,8,0" Padding="20" CornerRadius="12" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="电脑录像" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock x:Name="OverviewPcStatus" Text="未配置" Margin="0,8,0,12" Foreground="{DynamicResource AccentBlue}"/>
                            <TextBlock Text="使用电脑摄像头录像，可用摄像头识别面单，也兼容扫码枪" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}"/>
                            <Button x:Name="OverviewPcAction" Content="开始配置" Tag="pc-recording" Height="38" Margin="0,18,0,0" Style="{StaticResource PrimaryButtonStyle}" Focusable="False" Click="NavigationButton_Click"/>
                        </StackPanel>
                    </Border>
                    <Border Margin="8,0" Padding="20" CornerRadius="12" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="手机备份" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock x:Name="OverviewMobileStatus" Text="未配置" Margin="0,8,0,12" Foreground="{DynamicResource AccentBlue}"/>
                            <TextBlock Text="手机可独立录像，完成后备份到这台电脑并统一进入录像库" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}"/>
                            <Button x:Name="OverviewMobileAction" Content="开始配置" Tag="mobile-backup" Height="38" Margin="0,18,0,0" Style="{StaticResource PrimaryButtonStyle}" Focusable="False" Click="NavigationButton_Click"/>
                        </StackPanel>
                    </Border>
                    <Border Margin="8,0,0,0" Padding="20" CornerRadius="12" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="订单联动" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock x:Name="OverviewOrderStatus" Text="未配置" Margin="0,8,0,12" Foreground="{DynamicResource AccentBlue}"/>
                            <TextBlock Text="同步留言、备注、商品和退款信息，可同时发送到多台电脑" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}"/>
                            <Button x:Name="OverviewOrderAction" Content="开始配置" Tag="order-integration" Height="38" Margin="0,18,0,0" Style="{StaticResource PrimaryButtonStyle}" Focusable="False" Click="NavigationButton_Click"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
                <Border Margin="0,24,0,0" Padding="20" CornerRadius="12" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="当前录像" Foreground="{DynamicResource TextMuted}"/><TextBlock Text="{Binding CurrentOrderId, TargetNullValue=未在录像}" Margin="0,6,0,0" FontSize="16" Foreground="{DynamicResource TextPrimary}"/></StackPanel>
                        <StackPanel Grid.Column="1"><TextBlock Text="在线设备" Foreground="{DynamicResource TextMuted}"/><TextBlock Text="{Binding ConnectedDeviceText}" Margin="0,6,0,0" FontSize="16" Foreground="{DynamicResource TextPrimary}"/></StackPanel>
                        <StackPanel Grid.Column="2"><TextBlock Text="局域网地址" Foreground="{DynamicResource TextMuted}"/><TextBlock Text="{Binding MonitorAccessAddress}" Margin="0,6,0,0" FontSize="16" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis"/></StackPanel>
                    </Grid>
                </Border>
                <TextBlock Text="打包数据分析" Margin="0,28,0,4" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                <ContentControl x:Name="OverviewStatisticsContentHost"/>
            </StackPanel>
        </ScrollViewer>

        <Grid x:Name="MobileBackupModule" Visibility="Collapsed">
            <ContentControl x:Name="MobileBackupContentHost"/>
        </Grid>

        <Grid x:Name="OrderIntegrationModule" Visibility="Collapsed">
            <ContentControl x:Name="OrderIntegrationContentHost"/>
        </Grid>

        <Grid x:Name="VideoLibraryModule" Visibility="Collapsed">
            <ContentControl x:Name="VideoLibraryContentHost"/>
        </Grid>

        <Grid x:Name="SettingsModule" Visibility="Collapsed">
            <ContentControl x:Name="SettingsContentHost"/>
        </Grid>
        </Grid>

        <Border Grid.ColumnSpan="2" Background="{DynamicResource ToastBackground}" CornerRadius="8" Padding="32,16" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" Panel.ZIndex="1000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsToastVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding ToastMessage}" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>


