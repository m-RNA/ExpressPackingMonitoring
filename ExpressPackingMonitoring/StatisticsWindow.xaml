<Window x:Class="ExpressPackingMonitoring.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📊 数据统计看板" Height="650" Width="950"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource ControlBackground}"
        Icon="app.ico"
        FontFamily="Microsoft YaHei UI, Segoe UI">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.03"/>
            </Border.Effect>
            <Grid>
                <TextBlock Text="近 7 日打包效率趋势" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="本周总件数: " FontSize="16" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Bottom" Margin="0,0,8,2"/>
                    <TextBlock Text="{Binding WeekTotalPieces}" FontSize="24" FontWeight="Black" Foreground="{DynamicResource AccentPurple}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="20,40,20,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.03"/>
            </Border.Effect>
            <ItemsControl ItemsSource="{Binding ChartData}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" Columns="7"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" VerticalAlignment="Bottom" Background="{DynamicResource AccentBlue}" CornerRadius="4,4,0,0"
                                    Height="{Binding BarHeight}" Width="60">
                                <Border.ToolTip>
                                    <ToolTip Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderDefault}" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DateLabel}" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                                            <TextBlock Text="{Binding Pieces, StringFormat=打包件数: {0} 件}" Foreground="{DynamicResource AccentBlue}" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding TotalTime, StringFormat=总耗时: {0}}" Foreground="{DynamicResource AccentGreen}" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding AvgTime, StringFormat=平均耗时: {0}}" Foreground="{DynamicResource AccentOrange}"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                            </Border>

                            <!-- 修改：设置 Margin 时不再用 Padding 强顶，避免超出裁剪 -->
                            <!-- 设置上外边距给数字留出空间，移除硬性的 Margin 绑定 -->
                            <!-- 加上 RenderTransform 来实现纯相对位移，并且确保整体上层留出空间 -->
                            <TextBlock Grid.Row="0" Text="{Binding Pieces}" VerticalAlignment="Bottom" HorizontalAlignment="Center" 
                                       Margin="{Binding LabelMargin}" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}" FontSize="14">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform Y="-5"/> <!-- 微调文字和柱子的距离 -->
                                </TextBlock.RenderTransform>
                            </TextBlock>

                            <StackPanel Grid.Row="1" Margin="0,15,0,0" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DateLabel}" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding DateSubLabel}" Foreground="{DynamicResource TextMuted}" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </Grid>
</Window>


