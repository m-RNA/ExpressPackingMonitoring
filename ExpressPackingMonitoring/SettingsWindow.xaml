<Window x:Class="ExpressPackingMonitoring.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="设置" Height="760" Width="920"
        MinHeight="680" MinWidth="860"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Icon="app.ico"
        Background="{DynamicResource WindowBackground}" FontFamily="Microsoft YaHei UI, Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <!-- 【必需】1. GroupTitle: 用于每个页签顶部的巨大标题 -->
        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,25"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <!-- 【必需】2. SectionHeader: 用于小组标题（如“磁盘矩阵”、“识别规则”） -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,15,0,10"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        </Style>

        <!-- 【必需】3. SettingRow: 用于每一行设置项的容器边框 -->
        <Style x:Key="SettingRow" TargetType="Border">
            <Setter Property="Padding" Value="0,15"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <ControlTemplate x:Key="SettingsComboBoxToggleButtonTemplate" TargetType="{x:Type ToggleButton}">
            <Grid>
                <Border x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"/>
                <Grid Margin="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="34"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="1"
                            Margin="0,1,1,1"
                            Background="Transparent"
                            CornerRadius="0,7,7,0"/>
                    <Path x:Name="Arrow"
                          Grid.Column="1"
                          Width="9"
                          Height="5"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Fill="{DynamicResource TextSecondary}"
                          Stretch="Fill"
                          Data="M 0 0 L 4.5 5 L 9 0 Z"/>
                </Grid>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
                    <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource TextPrimary}"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                    <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource AccentBlue}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Chrome" Property="Opacity" Value="0.62"/>
                    <Setter TargetName="Arrow" Property="Opacity" Value="0.62"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="SettingsComboBoxTextBoxTemplate" TargetType="{x:Type TextBox}">
            <Border x:Name="PART_ContentHost"
                    Focusable="False"
                    Background="Transparent"/>
        </ControlTemplate>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <!-- 显式设置这些属性，切断系统默认样式中 FindAncestor 的错误绑定 -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ControlBackgroundHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ControlBackgroundHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource BorderLight}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.62"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Width" Value="260"/>
            <Setter Property="MinWidth" Value="220"/>
            <Setter Property="MaxWidth" Value="260"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource SettingsComboBoxToggleButtonTemplate}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,0,38,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <TextBox x:Name="PART_EditableTextBox"
                                     Style="{x:Null}"
                                     Template="{StaticResource SettingsComboBoxTextBoxTemplate}"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Margin="10,0,38,0"
                                     Focusable="True"
                                     Background="Transparent"
                                     Foreground="{TemplateBinding Foreground}"
                                     Visibility="Hidden"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Grid x:Name="DropDown"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                      SnapsToDevicePixels="True">
                                    <Border x:Name="DropDownBorder"
                                            Margin="0,4,0,0"
                                            Background="{DynamicResource PanelBackground}"
                                            BorderBrush="{DynamicResource BorderStrong}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="4">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.18"/>
                                        </Border.Effect>
                                        <ScrollViewer SnapsToDevicePixels="True"
                                                      CanContentScroll="True">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="88"/>
                            </Trigger>
                            <Trigger Property="IsGrouping" Value="True">
                                <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
                            </Trigger>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter Property="IsTabStop" Value="False"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.62"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsButtonSpinnerStyle" TargetType="{x:Type xctk:ButtonSpinner}">
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="1,0,0,0"/>
        </Style>

        <ControlTemplate x:Key="SettingsDoubleUpDownTemplate" TargetType="{x:Type xctk:DoubleUpDown}">
            <Border x:Name="Chrome"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Background="{TemplateBinding Background}"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition x:Name="SpinnerColumn" Width="28"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PART_TextBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{TemplateBinding Foreground}"
                             HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                             VerticalContentAlignment="Center"
                             Padding="{TemplateBinding Padding}"
                             Margin="0"
                             Focusable="True"/>
                    <Border x:Name="SpinnerHost"
                            Grid.Column="1"
                            Background="{DynamicResource ControlBackground}"
                            BorderBrush="{DynamicResource BorderLight}"
                            BorderThickness="1,0,0,0"
                            CornerRadius="0,8,8,0">
                        <xctk:ButtonSpinner x:Name="PART_Spinner"
                                            Style="{StaticResource SettingsButtonSpinnerStyle}"
                                            IsTabStop="False"
                                            Margin="0"
                                            BorderThickness="0"
                                            Background="Transparent"
                                            Foreground="{DynamicResource TextSecondary}"
                                            AllowSpin="{TemplateBinding AllowSpin}"
                                            ShowButtonSpinner="{TemplateBinding ShowButtonSpinner}"/>
                    </Border>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.62"/>
                </Trigger>
                <Trigger Property="ShowButtonSpinner" Value="False">
                    <Setter TargetName="SpinnerColumn" Property="Width" Value="0"/>
                    <Setter TargetName="SpinnerHost" Property="Visibility" Value="Collapsed"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="SettingsIntegerUpDownTemplate" TargetType="{x:Type xctk:IntegerUpDown}">
            <Border x:Name="Chrome"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Background="{TemplateBinding Background}"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition x:Name="SpinnerColumn" Width="28"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PART_TextBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{TemplateBinding Foreground}"
                             HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                             VerticalContentAlignment="Center"
                             Padding="{TemplateBinding Padding}"
                             Margin="0"
                             Focusable="True"/>
                    <Border x:Name="SpinnerHost"
                            Grid.Column="1"
                            Background="{DynamicResource ControlBackground}"
                            BorderBrush="{DynamicResource BorderLight}"
                            BorderThickness="1,0,0,0"
                            CornerRadius="0,8,8,0">
                        <xctk:ButtonSpinner x:Name="PART_Spinner"
                                            Style="{StaticResource SettingsButtonSpinnerStyle}"
                                            IsTabStop="False"
                                            Margin="0"
                                            BorderThickness="0"
                                            Background="Transparent"
                                            Foreground="{DynamicResource TextSecondary}"
                                            AllowSpin="{TemplateBinding AllowSpin}"
                                            ShowButtonSpinner="{TemplateBinding ShowButtonSpinner}"/>
                    </Border>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.62"/>
                </Trigger>
                <Trigger Property="ShowButtonSpinner" Value="False">
                    <Setter TargetName="SpinnerColumn" Property="Width" Value="0"/>
                    <Setter TargetName="SpinnerHost" Property="Visibility" Value="Collapsed"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="{x:Type xctk:IntegerUpDown}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="MaxWidth" Value="120"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ShowButtonSpinner" Value="False"/>
            <Setter Property="Template" Value="{StaticResource SettingsIntegerUpDownTemplate}"/>
        </Style>

        <Style TargetType="{x:Type xctk:DoubleUpDown}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="MaxWidth" Value="120"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ShowButtonSpinner" Value="False"/>
            <Setter Property="Template" Value="{StaticResource SettingsDoubleUpDownTemplate}"/>
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <Style x:Key="SectionHintStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <Style x:Key="FieldHintStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,3,0,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="16"/>
        </Style>

        <Style x:Key="SettingRowStyle" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.58"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionDividerStyle" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
            <Setter Property="Margin" Value="0,12,0,14"/>
        </Style>

        <!-- 5. 按钮基础样式 -->
        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsScrollBarPageButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsScrollThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbChrome"
                                Background="{DynamicResource BorderStrong}"
                                CornerRadius="5"
                                Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="{DynamicResource TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="12"/>
            <Setter Property="MinWidth" Value="12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root"
                              Background="{TemplateBinding Background}"
                              Width="{TemplateBinding Width}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton x:Name="PageDecreaseButton"
                                                  Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource SettingsScrollBarPageButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SettingsScrollThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton x:Name="PageIncreaseButton"
                                                  Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource SettingsScrollBarPageButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="Height" Value="12"/>
                                <Setter TargetName="Root" Property="Width" Value="Auto"/>
                                <Setter TargetName="Root" Property="Height" Value="12"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                                <Setter TargetName="PageDecreaseButton" Property="Command" Value="{x:Static ScrollBar.PageLeftCommand}"/>
                                <Setter TargetName="PageIncreaseButton" Property="Command" Value="{x:Static ScrollBar.PageRightCommand}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="MainGrid" Width="44" Height="24" VerticalAlignment="Center">
                            <Border x:Name="BorderUnchecked" CornerRadius="12" Background="{DynamicResource BorderStrong}"/>
                            <Border x:Name="BorderChecked" CornerRadius="12" Background="{DynamicResource AccentBlue}" Opacity="0"/>
                            <Ellipse x:Name="Knob" Width="20" Height="20" Fill="White" HorizontalAlignment="Left" Margin="2,0,0,0">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform X="0"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2" Direction="270"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Knob"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="20" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="BorderChecked"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Knob"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="BorderChecked"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="MainGrid"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.8" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="MainGrid"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0"
                    TabStripPlacement="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    Margin="0,0,0,18">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid KeyboardNavigation.TabNavigation="Local">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="174"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{DynamicResource ControlBackground}"
                                BorderBrush="{DynamicResource BorderLight}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="8">
                            <TabPanel IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1"/>
                        </Border>

                        <ContentPresenter x:Name="PART_SelectedContentHost"
                                          Grid.Column="1"
                                          ContentSource="SelectedContent"
                                          Margin="18,0,0,0"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="14,11"/>
                    <Setter Property="Margin" Value="0,0,0,6"/>
                    <Setter Property="MinWidth" Value="156"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Background="{TemplateBinding Background}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        CornerRadius="8">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                        <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                            <Condition Property="IsSelected" Value="False"/>
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                        <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <TabItem Header="设备与画面">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="基础设置" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="先选这台电脑的用途和界面外观。"
                                               Style="{StaticResource SectionHintStyle}"/>
                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="工位用途" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="选择这台电脑负责录像还是打印。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox Grid.Column="2"
                                                  SelectedValue="{Binding Config.WorkstationRole}"
                                                  SelectedValuePath="Tag"
                                                  Cursor="Hand">
                                            <ComboBoxItem Tag="CameraMonitor">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource FluentVideoIcon}" Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource AccentBlue}" Margin="0,0,8,0"/>
                                                    <TextBlock Text="摄像头监控工位"/>
                                                </StackPanel>
                                            </ComboBoxItem>
                                            <ComboBoxItem Tag="PrintStation">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource FluentPrinterIcon}" Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource AccentOrange}" Margin="0,0,8,0"/>
                                                    <TextBlock Text="快递单打印工位"/>
                                                </StackPanel>
                                            </ComboBoxItem>
                                        </ComboBox>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="外观主题" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="可跟随系统，或固定为浅色 / 深色主题。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ThemeComboBox"
                                                  Grid.Column="2"
                                                  SelectedValue="{Binding Config.Theme}"
                                                  SelectedValuePath="Content"
                                                  Cursor="Hand"
                                                  SelectionChanged="ThemeComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Auto"/>
                                            <ComboBoxItem Content="Light"/>
                                            <ComboBoxItem Content="Dark"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="摄像头" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="选择拍摄打包过程的摄像头。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="CameraComboBox"
                                                  Grid.Column="2"
                                                  SelectedValuePath="Index"
                                                  DisplayMemberPath="Name"
                                                  SelectedValue="{Binding Config.CameraIndex}"
                                                  SelectionChanged="CameraComboBox_SelectionChanged"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="录制声音" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="需要保留现场声音时开启。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="AudioRecordCheckBox"
                                                  Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableAudioRecording}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}"
                                          IsEnabled="{Binding IsChecked, ElementName=AudioRecordCheckBox, TargetNullValue=False}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="麦克风" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="选择录制声音使用的麦克风。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="MicComboBox"
                                                  Grid.Column="2"
                                                  SelectedValuePath="Name"
                                                  DisplayMemberPath="Name"
                                                  SelectedValue="{Binding Config.AudioDeviceName}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="录像画质" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="调整录像清晰度、文件大小和电脑占用。"
                                               Style="{StaticResource SectionHintStyle}"/>
                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}"
                                          ToolTip="H.265/HEVC 体积更小，但部分电脑或浏览器可能无法直接播放；H.264 兼容性更好。">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="视频编码格式" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="影响录像体积和播放兼容性。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="VideoCodecComboBox"
                                                  Grid.Column="2"
                                                  SelectedValuePath="Value"
                                                  DisplayMemberPath="DisplayName"
                                                  Cursor="Hand"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}"
                                          ToolTip="优先使用显卡进行视频编码，可降低 CPU 占用；如果录像异常，可改为自动或 CPU。">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="硬件加速" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="用显卡帮忙录像，降低电脑占用。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="GpuEncoderComboBox"
                                                  Grid.Column="2"
                                                  SelectedValuePath="Value"
                                                  DisplayMemberPath="DisplayName"
                                                  Cursor="Hand"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="分辨率" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="越高越清晰，文件也越大。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ResComboBox"
                                                  Grid.Column="2"
                                                  DisplayMemberPath="Name"
                                                  Cursor="Hand"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="画面流畅度" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="越高越流畅，也更占空间。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="FpsComboBox" Grid.Column="2"
                                                  Height="32"
                                                  Cursor="Hand"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,12,0,0"
                                          ToolTip="CQP/CQ/CRF/QP 是视频编码质量参数。默认 25，建议普通用户不要修改。">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="录像清晰度" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="数值越小越清晰，文件越大。普通用户建议保持默认。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:IntegerUpDown Grid.Column="2"
                                                           Height="36"
                                                           Value="{Binding Config.VideoCqp}"
                                                           Minimum="1"
                                                           Maximum="51"
                                                           Increment="1"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,12,0,0"
                                          ToolTip="负数表示让音频提前，正数表示让音频延后；通常保持 0。">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="声音同步微调" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="只有声音和画面不同步时再调整。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:IntegerUpDown Grid.Column="2"
                                                           Height="36"
                                                           Value="{Binding Config.AudioSyncOffsetMs}"
                                                           Minimum="-5000"
                                                           Maximum="5000"
                                                           Increment="50"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="面单放大">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="开始录制时，画面会自动向中心放大一段时间，方便拍清快递面单。"
                                               Style="{StaticResource SectionHintStyle}"
                                               Margin="0,0,0,14"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="启用面单放大" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="录制开始时先放大中心画面，停留一会儿后再恢复。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="SmartZoomCheckBox"
                                                  Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableSmartZoom}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}"
                                    IsEnabled="{Binding IsChecked, ElementName=SmartZoomCheckBox, TargetNullValue=False}">
                                <StackPanel>
                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="放大倍数" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="倍率越高，面单越清楚，但画面范围越小。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ZoomScaleComboBox"
                                                  Grid.Column="2"
                                                  SelectedItem="{Binding Config.ZoomScale}"
                                                  SelectionChanged="ZoomScaleComboBox_SelectionChanged"
                                                  Cursor="Hand"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="放大前等待 / 秒" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="开始录制后等待多久再放大。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="2"
                                                           Height="36"
                                                           Value="{Binding Config.ZoomDelaySeconds}"
                                                           Minimum="0"
                                                           Increment="0.5"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="放大停留时间 / 秒" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="放大画面保持多久后恢复。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="2"
                                                           Height="36"
                                                           Value="{Binding Config.ZoomDurationSeconds}"
                                                           Minimum="0"
                                                           Increment="0.5"/>
                                    </Grid>

                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="平滑过渡" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="开启后放大和恢复时会有平滑动画。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ZoomAnimationCheckBox"
                                                  Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableZoomAnimation}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,0"
                                          IsEnabled="{Binding IsChecked, ElementName=ZoomAnimationCheckBox, TargetNullValue=False}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="过渡时长 / 毫秒" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="动画持续时间。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="2"
                                                           Height="36"
                                                           Value="{Binding Config.ZoomAnimationDurationMs}"
                                                           Minimum="50"
                                                           Maximum="2000"
                                                           Increment="50"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="录制控制">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="提示与录制时长" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="控制提醒声音，以及录像什么时候自动结束。"
                                               Style="{StaticResource SectionHintStyle}"/>
                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="启用声音提示" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="超时或关键事件发生时播放提醒音。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableSoundPrompt}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="超时预警提前 / 秒" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="在超时前提前提醒，给操作员留出处理时间。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="2"
                                                           Height="36"
                                                           Value="{Binding Config.TimeoutWarningSeconds}"
                                                           Minimum="3"
                                                           Maximum="120"
                                                           Increment="1"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="画面没变化时自动结束录像" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="打包结束后画面不动，就自动停止录像。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="AutoStopCheckBox"
                                                  Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableAutoStop}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}"
                                          Margin="0,0,0,14"
                                          IsEnabled="{Binding IsChecked, ElementName=AutoStopCheckBox, TargetNullValue=False}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="静止超时 / 分钟" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="画面不动超过这个时间后停止录像。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="2"
                                                           Height="36"
                                                           Value="{Binding Config.AutoStopMinutes}"
                                                           Minimum="0.1"
                                                           Maximum="60.0"
                                                           Increment="0.5"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="限制录像时长" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="防止单个录像录得太久。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="MaxDurationCheckBox"
                                                  Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableMaxDuration}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}"
                                          Margin="0,0,0,0"
                                          IsEnabled="{Binding IsChecked, ElementName=MaxDurationCheckBox, TargetNullValue=False}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="最大时长 / 分钟" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="单个录像超过这个时间就自动停止。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="2"
                                                           Height="36"
                                                           Value="{Binding Config.MaxDurationMinutes}"
                                                           Minimum="0.1"
                                                           Maximum="60.0"
                                                           Increment="0.5"/>
                                    </Grid>

                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="太短的视频自动丢弃" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="少于这个时长的视频不保存。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="2"
                                                           Height="36"
                                                           Value="{Binding Config.MinRecordingSeconds}"
                                                           Minimum="0"
                                                           Maximum="30"
                                                           Increment="1"/>
                                    </Grid>

                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="长时间不用时关闭摄像头" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="空闲时省资源，有操作时再恢复。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="CameraIdleCheckBox"
                                                  Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableCameraIdle}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,0"
                                          IsEnabled="{Binding IsChecked, ElementName=CameraIdleCheckBox, TargetNullValue=False}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="空闲超时 / 分钟" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="空闲超过这个时间后关闭摄像头。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="2"
                                                           Height="36"
                                                           Value="{Binding Config.CameraIdleMinutes}"
                                                           Minimum="1"
                                                           Maximum="480"
                                                           Increment="5"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
            <TabItem Header="存储管理">
                <Border Background="Transparent" Padding="18,0,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="录像保存位置" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="设置录像保存到哪里，以及每个位置最多用多少空间。"
                                               Style="{StaticResource SectionHintStyle}"/>
                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Border BorderBrush="{DynamicResource BorderLight}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Background="{DynamicResource ControlBackground}">
                                        <DataGrid x:Name="StorageDataGrid"
                                                  ItemsSource="{Binding Config.StorageLocations}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="Horizontal"
                                                  HorizontalGridLinesBrush="{DynamicResource BorderLight}"
                                                  BorderThickness="0"
                                                  Background="Transparent"
                                                  Foreground="{DynamicResource TextPrimary}"
                                                  RowHeight="50"
                                                  FontSize="13"
                                                  SelectionMode="Single"
                                                  CanUserSortColumns="False">
                                            <DataGrid.ColumnHeaderStyle>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                    <Setter Property="Padding" Value="12,10"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
                                                </Style>
                                            </DataGrid.ColumnHeaderStyle>
                                            <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource ControlBackgroundHover}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.RowStyle>
                                            <DataGrid.CellStyle>
                                                <Style TargetType="DataGridCell">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
                                                    <Setter Property="Padding" Value="6,0"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource ControlBackgroundHover}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.CellStyle>

                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Header="存储路径" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Path}"
                                                                       Foreground="{DynamicResource TextPrimary}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="12,0"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding Path}"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>

                                                <DataGridTemplateColumn Header="最大容量 (GB)" Width="150">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <xctk:DoubleUpDown ToolTip="最多允许这个目录保存多少 GB 录像。" Value="{Binding QuotaGB, UpdateSourceTrigger=PropertyChanged}"
                                                                               Minimum="1"
                                                                               Maximum="10000"
                                                                               Margin="5"
                                                                               VerticalAlignment="Center"
                                                                               HorizontalAlignment="Center"
                                                                               Width="96"
                                                                               MinWidth="96"
                                                                               MaxWidth="96"
                                                                               Height="36"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>

                                                <DataGridTemplateColumn Header="使用顺序" Width="140">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <xctk:IntegerUpDown ToolTip="数字越小越先使用，普通用户可不改。" Value="{Binding Priority, UpdateSourceTrigger=PropertyChanged}"
                                                                                Minimum="0"
                                                                                Maximum="99"
                                                                                Margin="5"
                                                                                VerticalAlignment="Center"
                                                                                HorizontalAlignment="Center"
                                                                                Width="96"
                                                                                MinWidth="96"
                                                                                MaxWidth="96"
                                                                                Height="36"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                                        <Button Content="添加磁盘"
                                                Click="BtnAddStorage_Click"
                                                Style="{StaticResource SecondaryActionButtonStyle}"
                                                Width="110"
                                                Margin="0,0,10,0"/>
                                        <Button Content="移除选中"
                                                Click="BtnRemoveStorage_Click"
                                                Style="{StaticResource SecondaryActionButtonStyle}"
                                                Width="110"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="回放列表" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="控制已清理的视频记录是否还出现在回放列表。"
                                               Style="{StaticResource SectionHintStyle}"/>
                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="显示已覆盖记录" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="视频文件被清理后，列表里仍显示这条记录。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="2"
                                                  IsChecked="{Binding Config.ShowDeletedVideos}"
                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="历史数据迁移" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="把旧版本录像转换成更容易播放的格式。"
                                               Style="{StaticResource SectionHintStyle}"/>
                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0,0,16,0" VerticalAlignment="Center">
                                                <TextBlock Text="旧录像转 MP4" Style="{StaticResource FieldLabelStyle}"/>
                                                <TextBlock x:Name="MigrationStatusText"
                                                           Text="需要整理旧录像时再使用。"
                                                           Style="{StaticResource FieldHintStyle}"/>
                                            </StackPanel>
                                            <Button x:Name="BtnMigrateMkv"
                                                    Grid.Column="1"
                                                    Content="开始迁移"
                                                    HorizontalAlignment="Right"
                                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                                    Width="100"
                                                    Click="BtnMigrateMkv_Click"/>
                                        </Grid>
                                        <ProgressBar x:Name="MigrationProgress"
                                                     Grid.Row="1"
                                                     Height="4"
                                                     Margin="0,12,0,0"
                                                     Visibility="Collapsed"
                                                     IsIndeterminate="True"
                                                     Foreground="{DynamicResource AccentBlue}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="AI 语音">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="语音播报" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="设置订单提醒时使用什么声音。"
                                               Style="{StaticResource SectionHintStyle}"/>
                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="启用 AI 语音" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="开启后播报声音更自然，关闭后使用系统默认语音。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="AiTtsCheckBox"
                                                  Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableAiTts}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}"
                                          ToolTip="Edge TTS 使用微软在线语音，声音自然；Kokoro 是本地模型，需要额外运行依赖。"
                                          IsEnabled="{Binding IsChecked, ElementName=AiTtsCheckBox, TargetNullValue=False}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="语音引擎" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="选择语音播报使用的声音来源。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="AiTtsEngineComboBox"
                                                  Grid.Column="2"
                                                  Width="220"
                                                  HorizontalAlignment="Left"
                                                  SelectedValue="{Binding Config.AiTtsEngine}"
                                                  SelectedValuePath="Tag">
                                            <ComboBoxItem Content="联网生成语音" Tag="Edge"/>
                                            <ComboBoxItem Content="离线生成语音" Tag="Kokoro"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0"
                                          IsEnabled="{Binding IsChecked, ElementName=AiTtsCheckBox, TargetNullValue=False}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="语速" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="调整播报快慢。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="2"
                                                           Height="36"
                                                           Value="{Binding Config.AiTtsSpeed}"
                                                           Minimum="0.5"
                                                           Maximum="2.0"
                                                           Increment="0.1"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}"
                                    IsEnabled="{Binding IsChecked, ElementName=AiTtsCheckBox, TargetNullValue=False}">
                                <StackPanel>
                                    <TextBlock Text="播报声音" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="给正常提示和警告提示选择不同声音。"
                                               Style="{StaticResource SectionHintStyle}"/>
                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid ToolTip="Kokoro 声线编号由本地模型决定；不了解时保持默认即可。">
                                        <Grid.Style>
                                            <Style TargetType="Grid" BasedOn="{StaticResource SettingRowStyle}">
                                                <Setter Property="IsEnabled" Value="False"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedValue, ElementName=AiTtsEngineComboBox}" Value="Kokoro">
                                                        <Setter Property="IsEnabled" Value="True"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="普通播报声线" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="用于正常订单提示。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:IntegerUpDown Grid.Column="2"
                                                            Height="36"
                                                            Value="{Binding Config.AiTtsSpeakerId}"
                                                            Minimum="0"
                                                            Maximum="102"
                                                            Increment="1"/>
                                    </Grid>

                                    <Grid ToolTip="建议与普通播报使用不同角色，便于区分警告提示。">
                                        <Grid.Style>
                                            <Style TargetType="Grid" BasedOn="{StaticResource SettingRowStyle}">
                                                <Setter Property="IsEnabled" Value="False"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedValue, ElementName=AiTtsEngineComboBox}" Value="Kokoro">
                                                        <Setter Property="IsEnabled" Value="True"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="警告播报声线" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="用于重复单号、非法单号等提醒。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:IntegerUpDown Grid.Column="2"
                                                            Height="36"
                                                            Value="{Binding Config.AiTtsWarningSpeakerId}"
                                                            Minimum="0"
                                                            Maximum="102"
                                                            Increment="1"/>
                                    </Grid>

                                    <Grid ToolTip="Edge 声线来自微软在线语音服务，网络不可用时会回退到系统语音。">
                                        <Grid.Style>
                                            <Style TargetType="Grid" BasedOn="{StaticResource SettingRowStyle}">
                                                <Setter Property="IsEnabled" Value="False"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedValue, ElementName=AiTtsEngineComboBox}" Value="Edge">
                                                        <Setter Property="IsEnabled" Value="True"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="在线普通声音" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="使用在线语音时的普通提示声音。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox Grid.Column="2"
                                                  Width="260"
                                                  HorizontalAlignment="Left"
                                                  IsTextSearchEnabled="True"
                                                  ItemsSource="{Binding EdgeVoiceOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="ShortName"
                                                  SelectedValue="{Binding Config.EdgeTtsVoice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>

                                    <Grid ToolTip="Edge 声线来自微软在线语音服务，网络不可用时会回退到系统语音。">
                                        <Grid.Style>
                                            <Style TargetType="Grid" BasedOn="{StaticResource SettingRowStyle}">
                                                <Setter Property="IsEnabled" Value="False"/>
                                                <Setter Property="Margin" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedValue, ElementName=AiTtsEngineComboBox}" Value="Edge">
                                                        <Setter Property="IsEnabled" Value="True"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="在线警告声音" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="使用在线语音时的警告提示声音。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox Grid.Column="2"
                                                  Width="260"
                                                  HorizontalAlignment="Left"
                                                  IsTextSearchEnabled="True"
                                                  ItemsSource="{Binding EdgeVoiceOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="ShortName"
                                                  SelectedValue="{Binding Config.EdgeTtsWarningVoice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}"
                                    IsEnabled="{Binding IsChecked, ElementName=AiTtsCheckBox, TargetNullValue=False}">
                                <StackPanel>
                                    <TextBlock Text="试听与断句" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="先试听播报效果，再按商品名调整停顿。"
                                               Style="{StaticResource SectionHintStyle}"/>
                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                            <TextBlock Text="语音预览" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="输入一段文字，试听当前播报效果。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <TextBox x:Name="TtsPreviewTextBox" Grid.Row="1" Height="60"
                                                 AcceptsReturn="True" TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Text="打包监控程序官方开源软件适用中小电商"/>
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                                            <Button Content="播放" x:Name="BtnTtsPreview" Click="BtnTtsPreview_Click"
                                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                                    Width="70" Margin="0,0,8,0"/>
                                            <Button Content="停止" x:Name="BtnTtsStop" Click="BtnTtsStop_Click"
                                                    Width="70" Margin="0,0,8,0" Height="34"/>
                                            <TextBlock x:Name="TtsPreviewStatus" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                            <TextBlock Text="断句关键词" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="商品名太长时，用这些词自动停顿。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <TextBox x:Name="TtsBreakWordsTextBox" Grid.Row="1" Height="100"
                                                 AcceptsReturn="True" TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="局域网查看">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="同一网络里的电脑或手机可以用浏览器查看录像。"
                                               Style="{StaticResource SectionHintStyle}"
                                               Margin="0,0,0,14"/>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="启用局域网查看" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="同一网络里的电脑或手机可以用浏览器查看录像。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableWebServer}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,14"
                                          ToolTip="端口是浏览器访问服务时使用的数字，例如 http://电脑IP:端口。">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="网页访问端口" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="浏览器访问用的端口，改完需重启。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:IntegerUpDown Grid.Column="2"
                                                            Height="36"
                                                            Value="{Binding Config.WebServerPort}"
                                                            Minimum="1024"
                                                            Maximum="65535"
                                                            Increment="1"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,14"
                                          ToolTip="缓存用于把部分视频临时转成更容易在线播放的格式，超出上限后会自动清理。">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="在线播放缓存上限 (MB)" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="在线播放部分视频时产生的临时缓存。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:IntegerUpDown Grid.Column="2"
                                                            Height="36"
                                                            Value="{Binding Config.TranscodeCacheMaxMB}"
                                                            Minimum="128"
                                                            Maximum="10240"
                                                            Increment="256"/>
                                    </Grid>

                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="安装联动助手" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="让快递助手页面把订单信息发送到监控工位。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Content="安装联动助手"
                                                Click="InstallTool_Click"
                                                Style="{StaticResource SecondaryActionButtonStyle}"
                                                Height="32"
                                                Padding="12,0"
                                                HorizontalAlignment="Left"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="订单信息播报" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="扫码打包时，自动播报订单备注、留言和商品信息。"
                                               Style="{StaticResource SectionHintStyle}"/>
                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="订单信息播报" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="扫码打包时，自动播报订单备注、留言和商品信息。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableOrderInfoAnnounce}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="24,8,0,0"
                                          Visibility="{Binding Config.EnableOrderInfoAnnounce, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="播报买家留言" Style="{StaticResource FieldLabelStyle}"/>
                                        <CheckBox Grid.Column="2"
                                                  IsChecked="{Binding Config.AnnounceBuyerMessage}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>
                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="24,8,0,0"
                                          Visibility="{Binding Config.EnableOrderInfoAnnounce, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="播报卖家备注" Style="{StaticResource FieldLabelStyle}"/>
                                        <CheckBox Grid.Column="2"
                                                  IsChecked="{Binding Config.AnnounceSellerMemo}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>
                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="24,8,0,0"
                                          Visibility="{Binding Config.EnableOrderInfoAnnounce, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="播报商品信息" Style="{StaticResource FieldLabelStyle}"/>
                                        <CheckBox Grid.Column="2"
                                                  IsChecked="{Binding Config.AnnounceProductInfo}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>
                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="24,8,0,0"
                                          Visibility="{Binding Config.EnableOrderInfoAnnounce, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="调试日志" Style="{StaticResource FieldLabelStyle}"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableOrderInfoLog}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
            <TabItem Header="高级设置">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="这些设置通常保持默认即可，只有需要调整扫码规则、开机启动或排查问题时再修改。"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14"/>
                            <!-- 水印设置 -->
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="视频水印" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="把单号和时间显示在录像画面上。"
                                               Style="{StaticResource SectionHintStyle}"/>
                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="启用录像水印" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="方便事后确认这段录像对应哪个订单。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableWatermark}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="扫码与启动" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="设置扫码枪输入、单号判断和开机启动。"
                                               Style="{StaticResource SectionHintStyle}"/>
                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="开机自启动" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="电脑开机后自动启动本程序。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="AutoStartCheckBox"
                                                  Grid.Column="2"
                                                  IsChecked="{Binding Config.AutoStartOnBoot}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="全局键盘监听" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="程序不在前台时也能接收扫码枪输入。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableGlobalKeyboard}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}"
                                          ToolTip="正则表达式用于过滤非法扫码内容。不了解正则时请不要修改。">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="单号判断规则" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="用于判断扫码内容是不是有效单号。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <TextBox Grid.Column="2"
                                                 HorizontalAlignment="Stretch"
                                                 Text="{Binding Config.OrderIdRegex}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,0"
                                          ToolTip="扫码枪可能连续发送多次内容，这里用于避免重复触发录制切换。">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="扫码间隔保护 (秒)" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="防止扫码枪连续触发太快。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="2"
                                                           Height="36"
                                                           Value="{Binding Config.BarcodeCooldownSeconds}"
                                                           Minimum="0.5"
                                                           Maximum="10.0"
                                                           Increment="0.5"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="维护工具" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="排查录像或硬件问题时再使用。"
                                               Style="{StaticResource SectionHintStyle}"/>
                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,0"
                                          ToolTip="清除已保存的显卡编码检测结果，下次重新判断可用编码器。">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="重置编码器检测" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="录像编码异常时，用它重新检测电脑能力。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="立即重新检测"
                                                Command="{Binding MainVM.ResetEncoderDetectCommand}"
                                                Style="{StaticResource SecondaryActionButtonStyle}"
                                                Height="32" Padding="12,0" HorizontalAlignment="Left" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="关于">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="关于与开源许可" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="查看项目源码、许可证和开源使用说明。"
                                               Style="{StaticResource SectionHintStyle}"/>
                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="项目仓库" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="打开 GitHub 仓库，查看源码、发布记录和问题反馈。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <WrapPanel Grid.Column="2">
                                            <Button Content="打开仓库"
                                                    Click="OpenRepository_Click"
                                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                                    Height="32"
                                                    Padding="12,0"
                                                    Margin="0,0,8,8"/>
                                            <Button Content="查看许可证"
                                                    Click="OpenLicense_Click"
                                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                                    Height="32"
                                                    Padding="12,0"
                                                    Margin="0,0,0,8"/>
                                        </WrapPanel>
                                    </Grid>

                                    <Border Background="{DynamicResource ControlBackground}"
                                            BorderBrush="{DynamicResource BorderDefault}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="12">
                                        <TextBlock TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="12"
                                                   LineHeight="19">
                                            <Run Text="本项目使用 AGPL-3.0 License 开源。"/>
                                            <LineBreak/>
                                            <LineBreak/>
                                            <Run Text="个人学习、自家店铺自用可以免费使用。"/>
                                            <LineBreak/>
                                            <Run Text="修改后对外分发或提供网络服务时，需要遵守 AGPL-3.0 的开源义务。"/>
                                            <LineBreak/>
                                            <Run Text="二次修改分发时请保留原作者署名、版权声明和许可证信息。"/>
                                            <LineBreak/>
                                            <Run Text="使用前请自行确认你的使用方式是否满足 AGPL-3.0 要求。"/>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
        </TabControl>

        <Border Grid.Row="1"
                BorderBrush="{DynamicResource BorderLight}"
                BorderThickness="1,1,0,0"
                Padding="0,14,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="存储空间"
                           Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,12,0"/>
                <ProgressBar Grid.Column="1"
                             Height="8"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding CurrentDiskUsagePercent}"
                             Foreground="{DynamicResource AccentBlue}"
                             Background="{DynamicResource BorderStrong}"
                             BorderThickness="0"
                             VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding CurrentDiskUsageText}"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>

                <UniformGrid Grid.Column="3" Rows="1" Columns="2" Width="220">
                    <Button Content="取消" Margin="0,0,10,0" Click="BtnCancel_Click" Style="{StaticResource SecondaryActionButtonStyle}"/>
                    <Button Content="保存应用" Click="BtnSave_Click" Style="{StaticResource PrimaryActionButtonStyle}"/>
                </UniformGrid>
            </Grid>
        </Border>
    </Grid>
</Window>




