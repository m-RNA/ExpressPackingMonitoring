<Window x:Class="ExpressPackingMonitoring.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="系统参数设置" Height="580" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F8FAFC" FontFamily="Microsoft YaHei UI, Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F1F5F9" CornerRadius="6" Padding="16,12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="磁盘占用:" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" Margin="12,0" Height="8" Minimum="0" Maximum="100" Value="{Binding CurrentDiskUsagePercent}" Foreground="#3B82F6" Background="#CBD5E1" BorderThickness="0"/>

                <TextBlock Grid.Column="2" Text="{Binding CurrentDiskUsageText}" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0,0,0,16">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="12,8"/>
                    <Setter Property="Foreground" Value="#64748B"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="#2563EB"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <TabItem Header="🎥 基础设备">
                <StackPanel Margin="10,20,10,0">
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="摄像头选择:" VerticalAlignment="Center" Foreground="#333" FontWeight="SemiBold"/>
                        <ComboBox x:Name="CameraComboBox" Grid.Column="1" SelectedValuePath="Index" DisplayMemberPath="Name" SelectedValue="{Binding Config.CameraIndex}" Padding="6"/>
                    </Grid>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="录像分辨率:" VerticalAlignment="Center" Foreground="#333" FontWeight="SemiBold"/>
                        <ComboBox x:Name="ResComboBox" Grid.Column="1" DisplayMemberPath="Name" Padding="6" Cursor="Hand"/>
                    </Grid>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="录制帧率 (FPS):" VerticalAlignment="Center" Foreground="#333" FontWeight="SemiBold"/>
                        <xctk:IntegerUpDown Grid.Column="1" Value="{Binding Config.Fps}" Minimum="5" Maximum="60" Padding="6"/>
                    </Grid>
                </StackPanel>
            </TabItem>

            <TabItem Header="🔍 智能特写">
                <StackPanel Margin="10,20,10,0">
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="启用智能特写:" VerticalAlignment="Center" Foreground="#333" FontWeight="SemiBold"/>
                        <CheckBox Grid.Column="1" IsChecked="{Binding Config.EnableSmartZoom}" VerticalAlignment="Center">
                            <CheckBox.LayoutTransform>
                                <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                            </CheckBox.LayoutTransform>
                        </CheckBox>
                    </Grid>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="特写放大倍数:" VerticalAlignment="Center" Foreground="#333" FontWeight="SemiBold"/>
                        <ComboBox x:Name="ZoomScaleComboBox" Grid.Column="1" SelectedItem="{Binding Config.ZoomScale}" Padding="6" Cursor="Hand"/>
                    </Grid>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="延迟触发 (秒):" VerticalAlignment="Center" Foreground="#333" FontWeight="SemiBold"/>
                        <xctk:DoubleUpDown Grid.Column="1" Value="{Binding Config.ZoomDelaySeconds}" Minimum="0" Increment="0.5" Padding="6"/>
                    </Grid>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="特写保持时间 (秒):" VerticalAlignment="Center" Foreground="#333" FontWeight="SemiBold"/>
                        <xctk:DoubleUpDown Grid.Column="1" Value="{Binding Config.ZoomDurationSeconds}" Minimum="0" Increment="0.5" Padding="6"/>
                    </Grid>
                </StackPanel>
            </TabItem>

            <TabItem Header="🛡️ 业务与防呆">
                <StackPanel Margin="10,20,10,0">
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="视频存储路径:" VerticalAlignment="Center" Foreground="#333" FontWeight="SemiBold"/>
                        <TextBox x:Name="PathTextBox" Grid.Column="1" Text="{Binding Config.VideoStoragePath}" Padding="6" IsReadOnly="True" Background="#F1F5F9" Foreground="#64748B"/>
                        <Button Grid.Column="2" Content="浏览" Width="60" Margin="8,0,0,0" Click="BtnBrowsePath_Click" Background="#E2E8F0" BorderThickness="0" Cursor="Hand" FontWeight="Bold">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="开启静止自动停录:" VerticalAlignment="Center" Foreground="#333" FontWeight="SemiBold"/>
                        <CheckBox Grid.Column="1" IsChecked="{Binding Config.EnableAutoStop}" VerticalAlignment="Center">
                            <CheckBox.LayoutTransform>
                                <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                            </CheckBox.LayoutTransform>
                        </CheckBox>
                    </Grid>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="静止超时 (分钟):" VerticalAlignment="Center" Foreground="#333" FontWeight="SemiBold"/>
                        <xctk:DoubleUpDown Grid.Column="1" Value="{Binding Config.AutoStopMinutes}" Minimum="0.1" Maximum="60.0" Increment="0.5" Padding="6"/>
                    </Grid>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="限制单次录像最大时长:" VerticalAlignment="Center" Foreground="#333" FontWeight="SemiBold"/>
                        <CheckBox Grid.Column="1" IsChecked="{Binding Config.EnableMaxDuration}" VerticalAlignment="Center">
                            <CheckBox.LayoutTransform><ScaleTransform ScaleX="1.3" ScaleY="1.3"/></CheckBox.LayoutTransform>
                        </CheckBox>
                    </Grid>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="最大录像时长 (分钟):" VerticalAlignment="Center" Foreground="#333" FontWeight="SemiBold"/>
                        <xctk:DoubleUpDown Grid.Column="1" Value="{Binding Config.MaxDurationMinutes}" Minimum="0.1" Maximum="60.0" Increment="0.5" Padding="6"/>
                    </Grid>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="防呆正则(单号):" VerticalAlignment="Center" Foreground="#333" FontWeight="SemiBold"/>
                        <TextBox Grid.Column="1" Text="{Binding Config.OrderIdRegex}" Padding="6"/>
                    </Grid>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="最大磁盘配额(GB):" VerticalAlignment="Center" Foreground="#333" FontWeight="SemiBold"/>
                        <xctk:DoubleUpDown Grid.Column="1" Value="{Binding Config.MaxDiskSpaceGB}" Minimum="0.5" Maximum="5000.0" Increment="0.5" Padding="6"/>
                    </Grid>
                </StackPanel>
            </TabItem>
        </TabControl>

        <UniformGrid Grid.Row="2" Rows="1" Columns="2" HorizontalAlignment="Right" Width="180">
            <Button Content="取消" Height="38" Margin="0,0,8,0" Click="BtnCancel_Click" Background="White" BorderBrush="#CBD5E1" BorderThickness="1" Foreground="#475569" FontWeight="SemiBold" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="保存应用" Height="38" Click="BtnSave_Click" Background="#2563EB" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </UniformGrid>
    </Grid>
</Window>