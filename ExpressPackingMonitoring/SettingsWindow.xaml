<Window x:Class="ExpressPackingMonitoring.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:local="clr-namespace:ExpressPackingMonitoring"
        Title="设置" Height="760" Width="920"
        MinHeight="680" MinWidth="860"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Icon="app.ico"
        Background="{DynamicResource WindowBackground}" FontFamily="Microsoft YaHei UI, Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:CqpToQualitySliderConverter x:Key="CqpToQualitySliderConverter"/>
        <local:IntSliderValueConverter x:Key="IntSliderValueConverter"/>
        <local:VideoQualityLabelConverter x:Key="VideoQualityLabelConverter"/>
        <!-- 【必需】1. GroupTitle: 用于每个页签顶部的巨大标题 -->
        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,25"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <!-- 【必需】2. SectionHeader: 用于小组标题（如“磁盘矩阵”、“识别规则”） -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,15,0,10"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        </Style>

        <!-- 【必需】3. SettingRow: 用于每一行设置项的容器边框 -->
        <Style x:Key="SettingRow" TargetType="Border">
            <Setter Property="Padding" Value="0,15"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <ControlTemplate x:Key="SettingsComboBoxToggleButtonTemplate" TargetType="{x:Type ToggleButton}">
            <Grid>
                <Border x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"/>
                <Grid Margin="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="34"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="1"
                            Margin="0,1,1,1"
                            Background="Transparent"
                            CornerRadius="0,7,7,0"/>
                    <Path x:Name="Arrow"
                          Grid.Column="1"
                          Width="9"
                          Height="5"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Fill="{DynamicResource TextSecondary}"
                          Stretch="Fill"
                          Data="M 0 0 L 4.5 5 L 9 0 Z"/>
                </Grid>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
                    <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource TextPrimary}"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                    <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource AccentBlue}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Chrome" Property="Opacity" Value="0.62"/>
                    <Setter TargetName="Arrow" Property="Opacity" Value="0.62"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="SettingsComboBoxTextBoxTemplate" TargetType="{x:Type TextBox}">
            <Border x:Name="PART_ContentHost"
                    Focusable="False"
                    Background="Transparent"/>
        </ControlTemplate>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <!-- 显式设置这些属性，切断系统默认样式中 FindAncestor 的错误绑定 -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ControlBackgroundHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ControlBackgroundHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource BorderLight}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.62"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Width" Value="260"/>
            <Setter Property="MinWidth" Value="220"/>
            <Setter Property="MaxWidth" Value="260"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource SettingsComboBoxToggleButtonTemplate}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,0,38,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <TextBox x:Name="PART_EditableTextBox"
                                     Style="{x:Null}"
                                     Template="{StaticResource SettingsComboBoxTextBoxTemplate}"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Margin="10,0,38,0"
                                     Focusable="True"
                                     Background="Transparent"
                                     Foreground="{TemplateBinding Foreground}"
                                     Visibility="Hidden"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Grid x:Name="DropDown"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                      SnapsToDevicePixels="True">
                                    <Border x:Name="DropDownBorder"
                                            Margin="0,4,0,0"
                                            Background="{DynamicResource PanelBackground}"
                                            BorderBrush="{DynamicResource BorderStrong}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="4">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.18"/>
                                        </Border.Effect>
                                        <ScrollViewer SnapsToDevicePixels="True"
                                                      CanContentScroll="True">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="88"/>
                            </Trigger>
                            <Trigger Property="IsGrouping" Value="True">
                                <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
                            </Trigger>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter Property="IsTabStop" Value="False"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.62"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsButtonSpinnerStyle" TargetType="{x:Type xctk:ButtonSpinner}">
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="1,0,0,0"/>
        </Style>

        <ControlTemplate x:Key="SettingsDoubleUpDownTemplate" TargetType="{x:Type xctk:DoubleUpDown}">
            <Border x:Name="Chrome"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Background="{TemplateBinding Background}"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition x:Name="UnitColumn" Width="Auto"/>
                        <ColumnDefinition x:Name="SpinnerColumn" Width="28"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PART_TextBox"
                             Background="Transparent"
                             BorderThickness="0"
                             CaretBrush="{DynamicResource AccentBlue}"
                             Foreground="{TemplateBinding Foreground}"
                             HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                             VerticalContentAlignment="Center"
                             Padding="{TemplateBinding Padding}"
                             Margin="0"
                             Focusable="True"/>
                    <TextBlock x:Name="UnitText"
                               Grid.Column="1"
                               Text="{TemplateBinding Tag}"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="12"
                               Margin="4,0,10,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                    <Border x:Name="SpinnerHost"
                            Grid.Column="2"
                            Background="{DynamicResource ControlBackground}"
                            BorderBrush="{DynamicResource BorderLight}"
                            BorderThickness="1,0,0,0"
                            CornerRadius="0,8,8,0">
                        <xctk:ButtonSpinner x:Name="PART_Spinner"
                                            Style="{StaticResource SettingsButtonSpinnerStyle}"
                                            IsTabStop="False"
                                            Margin="0"
                                            BorderThickness="0"
                                            Background="Transparent"
                                            Foreground="{DynamicResource TextSecondary}"
                                            AllowSpin="{TemplateBinding AllowSpin}"
                                            ShowButtonSpinner="{TemplateBinding ShowButtonSpinner}"/>
                    </Border>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.62"/>
                </Trigger>
                <Trigger Property="ShowButtonSpinner" Value="False">
                    <Setter TargetName="SpinnerColumn" Property="Width" Value="0"/>
                    <Setter TargetName="SpinnerHost" Property="Visibility" Value="Collapsed"/>
                </Trigger>
                <Trigger Property="Tag" Value="{x:Null}">
                    <Setter TargetName="UnitColumn" Property="Width" Value="0"/>
                    <Setter TargetName="UnitText" Property="Visibility" Value="Collapsed"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="SettingsIntegerUpDownTemplate" TargetType="{x:Type xctk:IntegerUpDown}">
            <Border x:Name="Chrome"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Background="{TemplateBinding Background}"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition x:Name="UnitColumn" Width="Auto"/>
                        <ColumnDefinition x:Name="SpinnerColumn" Width="28"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PART_TextBox"
                             Background="Transparent"
                             BorderThickness="0"
                             CaretBrush="{DynamicResource AccentBlue}"
                             Foreground="{TemplateBinding Foreground}"
                             HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                             VerticalContentAlignment="Center"
                             Padding="{TemplateBinding Padding}"
                             Margin="0"
                             Focusable="True"/>
                    <TextBlock x:Name="UnitText"
                               Grid.Column="1"
                               Text="{TemplateBinding Tag}"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="12"
                               Margin="4,0,10,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                    <Border x:Name="SpinnerHost"
                            Grid.Column="2"
                            Background="{DynamicResource ControlBackground}"
                            BorderBrush="{DynamicResource BorderLight}"
                            BorderThickness="1,0,0,0"
                            CornerRadius="0,8,8,0">
                        <xctk:ButtonSpinner x:Name="PART_Spinner"
                                            Style="{StaticResource SettingsButtonSpinnerStyle}"
                                            IsTabStop="False"
                                            Margin="0"
                                            BorderThickness="0"
                                            Background="Transparent"
                                            Foreground="{DynamicResource TextSecondary}"
                                            AllowSpin="{TemplateBinding AllowSpin}"
                                            ShowButtonSpinner="{TemplateBinding ShowButtonSpinner}"/>
                    </Border>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.62"/>
                </Trigger>
                <Trigger Property="ShowButtonSpinner" Value="False">
                    <Setter TargetName="SpinnerColumn" Property="Width" Value="0"/>
                    <Setter TargetName="SpinnerHost" Property="Visibility" Value="Collapsed"/>
                </Trigger>
                <Trigger Property="Tag" Value="{x:Null}">
                    <Setter TargetName="UnitColumn" Property="Width" Value="0"/>
                    <Setter TargetName="UnitText" Property="Visibility" Value="Collapsed"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="{x:Type xctk:IntegerUpDown}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="MaxWidth" Value="120"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ShowButtonSpinner" Value="False"/>
            <Setter Property="Template" Value="{StaticResource SettingsIntegerUpDownTemplate}"/>
        </Style>

        <Style TargetType="{x:Type xctk:DoubleUpDown}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="MaxWidth" Value="120"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ShowButtonSpinner" Value="False"/>
            <Setter Property="Template" Value="{StaticResource SettingsDoubleUpDownTemplate}"/>
        </Style>

        <Thickness x:Key="SectionCardMargin">0,0,0,16</Thickness>
        <Thickness x:Key="SettingRowMargin">0,0,0,14</Thickness>
        <Thickness x:Key="SettingRowLastMargin">0,0,0,0</Thickness>
        <Thickness x:Key="SettingChildRowMargin">24,8,0,0</Thickness>
        <Thickness x:Key="SettingInlineTopMargin">0,12,0,0</Thickness>
        <Thickness x:Key="SectionDividerMargin">0,14,0,14</Thickness>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="{StaticResource SectionCardMargin}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <Style x:Key="FieldHintStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,3,0,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="16"/>
        </Style>

        <Style x:Key="SettingRowStyle" TargetType="Grid">
            <Setter Property="Margin" Value="{StaticResource SettingRowMargin}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.58"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingRowLastStyle"
               TargetType="Grid"
               BasedOn="{StaticResource SettingRowStyle}">
            <Setter Property="Margin" Value="{StaticResource SettingRowLastMargin}"/>
        </Style>

        <Style x:Key="SettingRowBeforeDividerStyle"
               TargetType="Grid"
               BasedOn="{StaticResource SettingRowStyle}">
            <Setter Property="Margin" Value="{StaticResource SettingRowLastMargin}"/>
        </Style>

        <Style x:Key="SettingChildRowStyle"
               TargetType="Grid"
               BasedOn="{StaticResource SettingRowStyle}">
            <Setter Property="Margin" Value="{StaticResource SettingChildRowMargin}"/>
        </Style>

        <Style x:Key="SectionDividerStyle" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
            <Setter Property="Margin" Value="{StaticResource SectionDividerMargin}"/>
        </Style>

        <Style x:Key="SettingsSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="26"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TickPlacement" Value="None"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="AutoToolTipPlacement" Value="TopLeft"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="{TemplateBinding Height}" VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track"
                                   Grid.Row="0"
                                   Height="18"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  Focusable="False"
                                                  IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border x:Name="TrackFill"
                                                        Height="6"
                                                        Background="{DynamicResource AccentBlue}"
                                                        CornerRadius="3"
                                                        VerticalAlignment="Center"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="TrackFill" Property="Opacity" Value="0.9"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="TrackFill" Property="Opacity" Value="1"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  Focusable="False"
                                                  IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border x:Name="TrackRest"
                                                        Height="6"
                                                        Background="{DynamicResource ControlBackground}"
                                                        BorderBrush="{DynamicResource BorderStrong}"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        VerticalAlignment="Center"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="TrackRest" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                                                        <Setter TargetName="TrackRest" Property="Opacity" Value="0.9"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="SliderThumb"
                                           Width="16"
                                           Height="16"
                                           Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <Ellipse x:Name="ThumbGlow"
                                                             Width="22"
                                                             Height="22"
                                                             Fill="{DynamicResource AccentBlue}"
                                                             Opacity="0"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"/>
                                                    <Ellipse x:Name="ThumbChrome"
                                                             Width="16"
                                                             Height="16"
                                                             Fill="{DynamicResource ControlBackground}"
                                                             Stroke="{DynamicResource AccentBlue}"
                                                             StrokeThickness="2"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbGlow" Property="Opacity" Value="0.12"/>
                                                        <Setter TargetName="ThumbChrome" Property="Fill" Value="{DynamicResource ControlBackground}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbGlow" Property="Opacity" Value="0.2"/>
                                                        <Setter TargetName="ThumbChrome" Property="Fill" Value="{DynamicResource AccentBlue}"/>
                                                        <Setter TargetName="ThumbChrome" Property="Stroke" Value="{DynamicResource AccentBlue}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.58"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SliderValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>

        <Style x:Key="SliderEndLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        </Style>

        <Style x:Key="SliderRecommendedTextStyle" TargetType="TextBlock" BasedOn="{StaticResource SliderEndLabelStyle}">
            <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SettingsScrollBarPageButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsScrollThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbChrome"
                                Background="{DynamicResource BorderStrong}"
                                CornerRadius="5"
                                Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="{DynamicResource TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="12"/>
            <Setter Property="MinWidth" Value="12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root"
                              Background="{TemplateBinding Background}"
                              Width="{TemplateBinding Width}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton x:Name="PageDecreaseButton"
                                                  Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource SettingsScrollBarPageButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SettingsScrollThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton x:Name="PageIncreaseButton"
                                                  Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource SettingsScrollBarPageButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="Height" Value="12"/>
                                <Setter TargetName="Root" Property="Width" Value="Auto"/>
                                <Setter TargetName="Root" Property="Height" Value="12"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                                <Setter TargetName="PageDecreaseButton" Property="Command" Value="{x:Static ScrollBar.PageLeftCommand}"/>
                                <Setter TargetName="PageIncreaseButton" Property="Command" Value="{x:Static ScrollBar.PageRightCommand}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="MainGrid" Width="44" Height="24" VerticalAlignment="Center">
                            <Border x:Name="BorderUnchecked" CornerRadius="12" Background="{DynamicResource BorderStrong}"/>
                            <Border x:Name="BorderChecked" CornerRadius="12" Background="{DynamicResource AccentBlue}" Opacity="0"/>
                            <Ellipse x:Name="Knob" Width="20" Height="20" Fill="White" HorizontalAlignment="Left" Margin="2,0,0,0">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform X="0"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2" Direction="270"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Knob"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="20" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="BorderChecked"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Knob"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="BorderChecked"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="MainGrid"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.8" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="MainGrid"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0"
                    TabStripPlacement="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    Margin="0,0,0,18">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid KeyboardNavigation.TabNavigation="Local">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="174"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{DynamicResource ControlBackground}"
                                BorderBrush="{DynamicResource BorderLight}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="8">
                            <TabPanel IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1"/>
                        </Border>

                        <ContentPresenter x:Name="PART_SelectedContentHost"
                                          Grid.Column="1"
                                          ContentSource="SelectedContent"
                                          Margin="18,0,0,0"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="14,11"/>
                    <Setter Property="Margin" Value="0,0,0,6"/>
                    <Setter Property="MinWidth" Value="156"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Background="{TemplateBinding Background}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        CornerRadius="8">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                        <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                            <Condition Property="IsSelected" Value="False"/>
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                        <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <TabItem Header="设备与画面">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="工位用途" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="选择这台电脑负责录像还是打印"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox Grid.Column="2"
                                                  SelectedValue="{Binding Config.WorkstationRole}"
                                                  SelectedValuePath="Tag"
                                                  Cursor="Hand">
                                            <ComboBoxItem Tag="CameraMonitor">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource FluentVideoIcon}" Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource AccentBlue}" Margin="0,0,8,0"/>
                                                    <TextBlock Text="摄像头监控工位"/>
                                                </StackPanel>
                                            </ComboBoxItem>
                                            <ComboBoxItem Tag="PrintStation">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource FluentPrinterIcon}" Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource AccentOrange}" Margin="0,0,8,0"/>
                                                    <TextBlock Text="快递单打印工位"/>
                                                </StackPanel>
                                            </ComboBoxItem>
                                        </ComboBox>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="配置向导" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="重新检查打包模式、摄像头、麦克风和扫码枪"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Content="重新运行配置向导"
                                                Click="RunSetupWizard_Click"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                HorizontalAlignment="Left"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="外观主题" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="可跟随系统，或固定为浅色 / 深色主题"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ThemeComboBox"
                                                  Grid.Column="2"
                                                  SelectedValue="{Binding Config.Theme}"
                                                  SelectedValuePath="Tag"
                                                  Cursor="Hand"
                                                  SelectionChanged="ThemeComboBox_SelectionChanged">
                                            <ComboBoxItem Content="跟随系统" Tag="Auto"/>
                                            <ComboBoxItem Content="浅色主题" Tag="Light"/>
                                            <ComboBoxItem Content="深色主题" Tag="Dark"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="摄像头" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="选择拍摄打包过程的摄像头"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="CameraComboBox"
                                                  Grid.Column="2"
                                                  SelectedValuePath="Index"
                                                  DisplayMemberPath="Name"
                                                  SelectedValue="{Binding Config.CameraIndex}"
                                                  SelectionChanged="CameraComboBox_SelectionChanged"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="录制声音" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="需要保留现场声音时开启"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="AudioRecordCheckBox"
                                                  Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableAudioRecording}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowLastStyle}"
                                          IsEnabled="{Binding IsChecked, ElementName=AudioRecordCheckBox, TargetNullValue=False}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="麦克风" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="选择录制声音使用的麦克风"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="MicComboBox"
                                                  Grid.Column="2"
                                                  SelectedValuePath="Name"
                                                  DisplayMemberPath="Name"
                                                  SelectedValue="{Binding Config.AudioDeviceName}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <Grid Style="{StaticResource SettingRowStyle}"
                                          ToolTip="H.265/HEVC 体积更小，但部分电脑或浏览器可能无法直接播放；H.264 兼容性更好。">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="视频编码格式" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="影响录像体积和播放兼容性"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="VideoCodecComboBox"
                                                  Grid.Column="2"
                                                  SelectedValuePath="Value"
                                                  DisplayMemberPath="DisplayName"
                                                  Cursor="Hand"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}"
                                          ToolTip="优先使用显卡进行视频编码，可降低 CPU 占用；如果录像异常，可改为自动或 CPU。">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="硬件加速" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="用显卡帮忙录像，降低电脑占用"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="GpuEncoderComboBox"
                                                  Grid.Column="2"
                                                  SelectedValuePath="Value"
                                                  DisplayMemberPath="DisplayName"
                                                  Cursor="Hand"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="分辨率" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="越高越清晰，文件也越大"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ResComboBox"
                                                  Grid.Column="2"
                                                  DisplayMemberPath="Name"
                                                  Cursor="Hand"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="画面流畅度" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="越高越流畅，也更占空间"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="FpsComboBox" Grid.Column="2"
                                                  Height="32"
                                                  Cursor="Hand"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}"
                                          ToolTip="底层仍保存为 CQP。CQP 数值越小越清晰、文件越大；这里用更直观的方向显示。">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="画质与文件大小" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="往右更清晰，往左更省空间"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <Grid>
                                                <TextBlock Text="省空间" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="{Binding ElementName=VideoQualitySlider, Path=Value, Converter={StaticResource VideoQualityLabelConverter}}"
                                                           Style="{StaticResource SliderValueTextStyle}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="更清晰" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="VideoQualitySlider"
                                                    Style="{StaticResource SettingsSliderStyle}"
                                                    Minimum="0"
                                                    Maximum="100"
                                                    TickFrequency="2"
                                                    Value="{Binding Config.VideoCqp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource CqpToQualitySliderConverter}}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowLastStyle}"
                                          ToolTip="负数表示让音频提前，正数表示让音频延后；通常保持 0。">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="声音同步微调" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="只有声音和画面不同步时再调整"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:IntegerUpDown Grid.Column="2"
                                                           Height="36"
                                                           Tag="ms"
                                                           Value="{Binding Config.AudioSyncOffsetMs}"
                                                           Minimum="-5000"
                                                           Maximum="5000"
                                                           Increment="50"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="面单放大">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="启用面单放大" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="录制开始时先放大中心画面，停留一会儿后再恢复"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="SmartZoomCheckBox"
                                                  Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableSmartZoom}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}"
                                    IsEnabled="{Binding IsChecked, ElementName=SmartZoomCheckBox, TargetNullValue=False}">
                                <StackPanel>
                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="放大倍数" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="倍率越高，面单越清楚，但画面范围越小"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <Grid>
                                                <TextBlock Text="范围大" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="{Binding ElementName=ZoomScaleSlider, Path=Value, StringFormat={}{0:F1} 倍}"
                                                           Style="{StaticResource SliderValueTextStyle}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="面单大" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="ZoomScaleSlider"
                                                    Style="{StaticResource SettingsSliderStyle}"
                                                    Minimum="1.2"
                                                    Maximum="4.0"
                                                    TickFrequency="0.1"
                                                    Value="{Binding Config.ZoomScale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    ValueChanged="ZoomScaleSlider_ValueChanged"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="放大前等待" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="开始录制后等待多久再放大"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <Grid>
                                                <TextBlock Text="更快" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="{Binding ElementName=ZoomDelaySlider, Path=Value, StringFormat={}{0:F1} 秒}"
                                                           Style="{StaticResource SliderValueTextStyle}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="更慢" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="ZoomDelaySlider"
                                                    Style="{StaticResource SettingsSliderStyle}"
                                                    Minimum="0"
                                                    Maximum="5"
                                                    TickFrequency="0.5"
                                                    Value="{Binding Config.ZoomDelaySeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowBeforeDividerStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="放大停留时间" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="放大画面保持多久后恢复"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <Grid>
                                                <TextBlock Text="更短" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="{Binding ElementName=ZoomDurationSlider, Path=Value, StringFormat={}{0:F1} 秒}"
                                                           Style="{StaticResource SliderValueTextStyle}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="更长" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="ZoomDurationSlider"
                                                    Style="{StaticResource SettingsSliderStyle}"
                                                    Minimum="0"
                                                    Maximum="10"
                                                    TickFrequency="0.5"
                                                    Value="{Binding Config.ZoomDurationSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="平滑过渡" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="开启后放大和恢复时会有平滑动画"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ZoomAnimationCheckBox"
                                                  Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableZoomAnimation}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowLastStyle}"
                                          IsEnabled="{Binding IsChecked, ElementName=ZoomAnimationCheckBox, TargetNullValue=False}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="过渡时长" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="动画持续时间"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <Grid>
                                                <TextBlock Text="更快" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="{Binding ElementName=ZoomAnimationSlider, Path=Value, StringFormat={}{0:F0} ms}"
                                                           Style="{StaticResource SliderValueTextStyle}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="更柔和" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="ZoomAnimationSlider"
                                                    Style="{StaticResource SettingsSliderStyle}"
                                                    Minimum="50"
                                                    Maximum="2000"
                                                    TickFrequency="50"
                                                    Value="{Binding Config.ZoomAnimationDurationMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="录制控制">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="画面没变化时自动结束录像" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="打包结束后画面不动，就自动停止录像"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="AutoStopCheckBox"
                                                  Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableAutoStop}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}"
                                          IsEnabled="{Binding IsChecked, ElementName=AutoStopCheckBox, TargetNullValue=False}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="静止超时" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="画面不动超过这个时间后停止录像"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <Grid>
                                                <TextBlock Text="更短" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="{Binding ElementName=AutoStopSlider, Path=Value, StringFormat={}{0:F1} 分钟}"
                                                           Style="{StaticResource SliderValueTextStyle}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="更长" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="AutoStopSlider"
                                                    Style="{StaticResource SettingsSliderStyle}"
                                                    Minimum="0.1"
                                                    Maximum="60"
                                                    TickFrequency="0.5"
                                                    Value="{Binding Config.AutoStopMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowBeforeDividerStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="提前提醒时间" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="快要自动停止录像前，提前多久提醒"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <Grid>
                                                <TextBlock Text="更晚" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="{Binding ElementName=TimeoutWarningSlider, Path=Value, StringFormat={}{0:F0} 秒}"
                                                           Style="{StaticResource SliderValueTextStyle}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="更早" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="TimeoutWarningSlider"
                                                    Style="{StaticResource SettingsSliderStyle}"
                                                    Minimum="3"
                                                    Maximum="120"
                                                    TickFrequency="1"
                                                    Value="{Binding Config.TimeoutWarningSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="限制录像时长" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="防止单个录像录得太久"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="MaxDurationCheckBox"
                                                  Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableMaxDuration}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowBeforeDividerStyle}"
                                          IsEnabled="{Binding IsChecked, ElementName=MaxDurationCheckBox, TargetNullValue=False}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="最大时长" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="单个录像超过这个时间就自动停止"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <Grid>
                                                <TextBlock Text="更短" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="{Binding ElementName=MaxDurationSlider, Path=Value, StringFormat={}{0:F1} 分钟}"
                                                           Style="{StaticResource SliderValueTextStyle}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="更长" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="MaxDurationSlider"
                                                    Style="{StaticResource SettingsSliderStyle}"
                                                    Minimum="0.1"
                                                    Maximum="60"
                                                    TickFrequency="0.5"
                                                    Value="{Binding Config.MaxDurationMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid Style="{StaticResource SettingRowBeforeDividerStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="太短的视频自动丢弃" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="少于这个时长的视频不保存"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <Grid>
                                                <TextBlock Text="更宽松" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="{Binding ElementName=MinRecordingSlider, Path=Value, StringFormat={}{0:F0} 秒}"
                                                           Style="{StaticResource SliderValueTextStyle}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="更严格" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="MinRecordingSlider"
                                                    Style="{StaticResource SettingsSliderStyle}"
                                                    Minimum="0"
                                                    Maximum="30"
                                                    TickFrequency="1"
                                                    Value="{Binding Config.MinRecordingSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid Style="{StaticResource SettingRowBeforeDividerStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="仅限同码停录" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="再次扫描同一单号才停止录像，扫到其他单号不停止" Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableSameBarcodeStopRecording}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Border Style="{StaticResource SectionDividerStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="长时间不用时关闭摄像头" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="空闲时省资源，有操作时再恢复"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="CameraIdleCheckBox"
                                                  Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableCameraIdle}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowLastStyle}"
                                          IsEnabled="{Binding IsChecked, ElementName=CameraIdleCheckBox, TargetNullValue=False}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="空闲超时" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="空闲超过这个时间后关闭摄像头"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <Grid>
                                                <TextBlock Text="更快休眠" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="{Binding ElementName=CameraIdleSlider, Path=Value, StringFormat={}{0:F0} 分钟}"
                                                           Style="{StaticResource SliderValueTextStyle}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="更久在线" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="CameraIdleSlider"
                                                    Style="{StaticResource SettingsSliderStyle}"
                                                    Minimum="1"
                                                    Maximum="480"
                                                    TickFrequency="5"
                                                    Value="{Binding Config.CameraIdleMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
            <TabItem Header="存储管理">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="录像保存位置" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="配置录像保存磁盘和容量，录像会优先保存到列表靠上的磁盘。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Border BorderBrush="{DynamicResource BorderLight}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Background="{DynamicResource ControlBackground}">
                                        <DataGrid x:Name="StorageDataGrid"
                                                  ItemsSource="{Binding Config.StorageLocations}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="Horizontal"
                                                  HorizontalGridLinesBrush="{DynamicResource BorderLight}"
                                                  BorderThickness="0"
                                                  Background="Transparent"
                                                  Foreground="{DynamicResource TextPrimary}"
                                                  RowHeight="50"
                                                  FontSize="13"
                                                  SelectionMode="Single"
                                                  SelectionChanged="StorageDataGrid_SelectionChanged"
                                                  CanUserSortColumns="False">
                                            <DataGrid.ColumnHeaderStyle>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                    <Setter Property="Padding" Value="12,10"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
                                                </Style>
                                            </DataGrid.ColumnHeaderStyle>
                                            <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                                    <Style.Triggers>
                                                        <MultiTrigger>
                                                            <MultiTrigger.Conditions>
                                                                <Condition Property="IsMouseOver" Value="True"/>
                                                                <Condition Property="IsSelected" Value="False"/>
                                                            </MultiTrigger.Conditions>
                                                            <Setter Property="Background" Value="{DynamicResource ControlBackgroundHover}"/>
                                                        </MultiTrigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource BadgePackBg}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource BadgePackText}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.RowStyle>
                                            <DataGrid.CellStyle>
                                                <Style TargetType="DataGridCell">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                    <Setter Property="Padding" Value="6,0"/>
                                                    <Style.Triggers>
                                                        <MultiTrigger>
                                                            <MultiTrigger.Conditions>
                                                                <Condition Property="IsMouseOver" Value="True"/>
                                                                <Condition Property="IsSelected" Value="False"/>
                                                            </MultiTrigger.Conditions>
                                                            <Setter Property="Background" Value="{DynamicResource ControlBackgroundHover}"/>
                                                        </MultiTrigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource BadgePackBg}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource BadgePackText}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.CellStyle>

                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Header="存储路径" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Path}"
                                                                       Foreground="{DynamicResource TextPrimary}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="12,0"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding Path}"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>

                                                <DataGridTemplateColumn Header="使用容量" Width="150">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <xctk:DoubleUpDown ToolTip="最多允许这个目录保存多少 GB 录像。" Tag="GB" Value="{Binding QuotaGB, UpdateSourceTrigger=PropertyChanged}"
                                                                               Minimum="1"
                                                                               Maximum="10000"
                                                                               Margin="5"
                                                                               VerticalAlignment="Center"
                                                                               HorizontalAlignment="Center"
                                                                               Width="96"
                                                                               MinWidth="96"
                                                                               MaxWidth="96"
                                                                               Height="36"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>
                                    <TextBlock Text="录像会按照列表顺序依次存储；越靠上的磁盘越优先使用。磁盘达到使用容量后，会自动使用下一个磁盘。"
                                               Style="{StaticResource FieldHintStyle}"
                                               Margin="0,10,0,0"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource SettingInlineTopMargin}">
                                        <Button Content="添加磁盘"
                                                Click="BtnAddStorage_Click"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="0,0,10,0"/>
                                        <Button x:Name="RemoveStorageButton"
                                                Content="移除选中"
                                                Click="BtnRemoveStorage_Click"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="0,0,10,0"
                                                IsEnabled="False"/>
                                        <Button x:Name="MoveStorageUpButton"
                                                Content="上移"
                                                Click="BtnMoveStorageUp_Click"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="0,0,10,0"
                                                IsEnabled="False"/>
                                        <Button x:Name="MoveStorageDownButton"
                                                Content="下移"
                                                Click="BtnMoveStorageDown_Click"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                IsEnabled="False"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="最小文件大小" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="小于该大小的视频会自动删除；填 0 表示不限制"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <Grid>
                                                <TextBlock Text="更宽松" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="{Binding ElementName=MinVideoFileSizeSlider, Path=Value, StringFormat={}{0:F0} KB}"
                                                           Style="{StaticResource SliderValueTextStyle}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="更严格" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="MinVideoFileSizeSlider"
                                                    Style="{StaticResource SettingsSliderStyle}"
                                                    Minimum="0"
                                                    Maximum="20480"
                                                    TickFrequency="1024"
                                                    Value="{Binding Config.MinVideoFileSizeKB, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource IntSliderValueConverter}}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowLastStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="显示已清理记录" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="视频文件被清理后，列表里仍显示这条记录"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="2"
                                                  IsChecked="{Binding Config.ShowDeletedVideos}"
                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <Grid Style="{StaticResource SettingRowLastStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0" VerticalAlignment="Center">
                                            <TextBlock Text="旧录像转 MP4" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock x:Name="MigrationStatusText"
                                                       Text="需要整理旧录像时再使用"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <Button x:Name="BtnMigrateMkv"
                                                Grid.Column="2"
                                                Content="开始迁移"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="BtnMigrateMkv_Click"/>
                                    </Grid>
                                    <ProgressBar x:Name="MigrationProgress"
                                                 Height="4"
                                                 Margin="{StaticResource SettingInlineTopMargin}"
                                                 Visibility="Collapsed"
                                                 IsIndeterminate="True"
                                                 Foreground="{DynamicResource AccentBlue}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="AI 语音">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="语音提醒" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="开启后，超时、停录和订单信息会用语音提醒"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="SoundPromptCheckBox"
                                                  Grid.Column="2"
                                                  IsChecked="{Binding Config.EnableSoundPrompt}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}"
                                          ToolTip="系统语音不需要网络；联网语音声音更自然；离线语音使用本地模型，需要额外运行依赖。"
                                          IsEnabled="{Binding IsChecked, ElementName=SoundPromptCheckBox, TargetNullValue=False}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="语音引擎" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="选择提醒声音使用系统语音、联网语音还是离线语音"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="VoiceEngineComboBox"
                                                  Grid.Column="2"
