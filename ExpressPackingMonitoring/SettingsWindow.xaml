<Window x:Class="ExpressPackingMonitoring.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="设置" Height="680" Width="640"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Icon="app.ico"
        Background="{DynamicResource WindowBackground}" FontFamily="Microsoft YaHei UI, Segoe UI">

    <Window.Resources>
        <!-- 【必需】1. GroupTitle: 用于每个页签顶部的巨大标题 -->
        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,25"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <!-- 【必需】2. SectionHeader: 用于小组标题（如“磁盘矩阵”、“识别规则”） -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,15,0,10"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        </Style>

        <!-- 【必需】3. SettingRow: 用于每一行设置项的容器边框 -->
        <Style x:Key="SettingRow" TargetType="Border">
            <Setter Property="Padding" Value="0,15"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <!-- 显式设置这些属性，切断系统默认样式中 FindAncestor 的错误绑定 -->
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <Style TargetType="{x:Type xctk:IntegerUpDown}" BasedOn="{StaticResource {x:Type xctk:IntegerUpDown}}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
        </Style>

        <Style TargetType="{x:Type xctk:DoubleUpDown}" BasedOn="{StaticResource {x:Type xctk:DoubleUpDown}}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <Style x:Key="SectionHintStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <Style x:Key="FieldHintStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="16"/>
        </Style>

        <Style x:Key="SettingRowStyle" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.58"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 5. 按钮基础样式 -->
        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="MainGrid" Width="44" Height="24" VerticalAlignment="Center">
                            <Border x:Name="BorderUnchecked" CornerRadius="12" Background="{DynamicResource BorderStrong}"/>
                            <Border x:Name="BorderChecked" CornerRadius="12" Background="{DynamicResource AccentBlue}" Opacity="0"/>
                            <Ellipse x:Name="Knob" Width="20" Height="20" Fill="White" HorizontalAlignment="Left" Margin="2,0,0,0">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform X="0"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2" Direction="270"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Knob"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="20" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="BorderChecked"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Knob"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="BorderChecked"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="MainGrid"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.8" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="MainGrid"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18"
                Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="存储空间使用率" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,0"/>
                <ProgressBar Grid.Column="1"
                             Height="8"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding CurrentDiskUsagePercent}"
                             Foreground="{DynamicResource AccentBlue}"
                             Background="{DynamicResource BorderStrong}"
                             BorderThickness="0"
                             VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding CurrentDiskUsageText}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0,0,0,12">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="12,8"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0,0,0,3"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Background="{TemplateBinding Background}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        BorderBrush="{TemplateBinding BorderBrush}">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlueDark}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueDark}"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                            <Condition Property="IsSelected" Value="False"/>
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                        <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <TabItem Header="设备与画面">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="采集设备" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="这些选项决定录像来源和整体清晰度，建议优先确认。"
                                               Style="{StaticResource SectionHintStyle}"/>
                                    <Border Height="1" Background="{DynamicResource BorderLight}" Margin="0,12,0,12"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="外观主题" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="可跟随系统，或固定为浅色 / 深色主题。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ThemeComboBox"
                                                  Grid.Column="1"
                                                  SelectedValue="{Binding Config.Theme}"
                                                  SelectedValuePath="Content"
                                                  Cursor="Hand"
                                                  SelectionChanged="ThemeComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Auto"/>
                                            <ComboBoxItem Content="Light"/>
                                            <ComboBoxItem Content="Dark"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="摄像头" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="选择当前用于录制的采集设备。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="CameraComboBox"
                                                  Grid.Column="1"
                                                  SelectedValuePath="Index"
                                                  DisplayMemberPath="Name"
                                                  SelectedValue="{Binding Config.CameraIndex}"
                                                  SelectionChanged="CameraComboBox_SelectionChanged"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="录制声音" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="开启后同步录制麦克风音频，需系统安装 FFmpeg。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="AudioRecordCheckBox"
                                                  Grid.Column="1"
                                                  IsChecked="{Binding Config.EnableAudioRecording}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}"
                                          IsEnabled="{Binding IsChecked, ElementName=AudioRecordCheckBox, TargetNullValue=False}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="麦克风" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="选择用于录音的输入设备。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="MicComboBox"
                                                  Grid.Column="1"
                                                  SelectedValuePath="Name"
                                                  DisplayMemberPath="Name"
                                                  SelectedValue="{Binding Config.AudioDeviceName}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="录像质量" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="清晰度越高，占用空间越大；帧率越高，画面越流畅。"
                                               Style="{StaticResource SectionHintStyle}"/>
                                    <Border Height="1" Background="{DynamicResource BorderLight}" Margin="0,12,0,12"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="视频编码格式" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="H.265 压缩率更高（体积更小），但需要硬件支持。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="VideoCodecComboBox"
                                                  Grid.Column="1"
                                                  SelectedValuePath="Value"
                                                  DisplayMemberPath="DisplayName"
                                                  Cursor="Hand"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="硬件编码器 / GPU" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="优先使用独立显卡加速录像编码，降低 CPU 占用。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="GpuEncoderComboBox"
                                                  Grid.Column="1"
                                                  SelectedValuePath="Value"
                                                  DisplayMemberPath="DisplayName"
                                                  Cursor="Hand"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="分辨率" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="根据摄像头硬件能力自动列出可用分辨率。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ResComboBox"
                                                  Grid.Column="1"
                                                  DisplayMemberPath="Name"
                                                  Cursor="Hand"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="目标帧率 / FPS" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="根据摄像头硬件能力自动列出可用帧率。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="FpsComboBox" Grid.Column="1"
                                                  Height="32"
                                                  Cursor="Hand"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="编码质量 / CQP" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="默认 25。数值越小画质越高、体积越大；数值越大压缩越强。此值会映射到各编码器的 CQ/CRF/QP。默认录制容器为 MKV。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:IntegerUpDown Grid.Column="1"
                                                           Height="32"
                                                           Value="{Binding Config.VideoCqp}"
                                                           Minimum="1"
                                                           Maximum="51"
                                                           Increment="1"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="音频同步偏移 / ms" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="默认 -1000。负数表示让音频提前，正数表示让音频延后；0 表示不额外偏移。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:IntegerUpDown Grid.Column="1"
                                                           Height="32"
                                                           Value="{Binding Config.AudioSyncOffsetMs}"
                                                           Minimum="-5000"
                                                           Maximum="5000"
                                                           Increment="50"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="特写策略">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="启用智能特写" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="当系统识别到需要关注的画面时，自动放大关键区域。"
                                               Style="{StaticResource SectionHintStyle}"/>
                                    <Border Height="1" Background="{DynamicResource BorderLight}" Margin="0,12,0,12"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="智能特写开关" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="关闭后，下方特写参数不会参与录制逻辑。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="SmartZoomCheckBox"
                                                  Grid.Column="1"
                                                  IsChecked="{Binding Config.EnableSmartZoom}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}"
                                    IsEnabled="{Binding IsChecked, ElementName=SmartZoomCheckBox, TargetNullValue=False}">
                                <StackPanel>
                                    <TextBlock Text="特写参数" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="这些参数控制特写触发节奏和持续时间。"
                                               Style="{StaticResource SectionHintStyle}"/>
                                    <Border Height="1" Background="{DynamicResource BorderLight}" Margin="0,12,0,12"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="特写放大倍数" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="倍率越高，细节越清楚，但可见范围越小。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ZoomScaleComboBox"
                                                  Grid.Column="1"
                                                  SelectedItem="{Binding Config.ZoomScale}"
                                                  SelectionChanged="ZoomScaleComboBox_SelectionChanged"
                                                  Cursor="Hand"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="延迟触发 / 秒" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="用于过滤短暂抖动，避免频繁进入特写。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="1"
                                                           Height="32"
                                                           Value="{Binding Config.ZoomDelaySeconds}"
                                                           Minimum="0"
                                                           Increment="0.5"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="特写保持时间 / 秒" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="设置一次特写保持多久后再恢复常规视角。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="1"
                                                           Height="32"
                                                           Value="{Binding Config.ZoomDurationSeconds}"
                                                           Minimum="0"
                                                           Increment="0.5"/>
                                    </Grid>

                                    <Border Height="1" Background="{DynamicResource BorderLight}" Margin="0,12,0,12"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="缩放过渡动画" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="关闭后特写将瞬间切换，不带过渡效果。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ZoomAnimationCheckBox"
                                                  Grid.Column="1"
                                                  IsChecked="{Binding Config.EnableZoomAnimation}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,0"
                                          IsEnabled="{Binding IsChecked, ElementName=ZoomAnimationCheckBox, TargetNullValue=False}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="动画时长 / 毫秒" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="缩放过渡动画的持续时长，数值越大越柔和。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="1"
                                                           Height="32"
                                                           Value="{Binding Config.ZoomAnimationDurationMs}"
                                                           Minimum="50"
                                                           Maximum="2000"
                                                           Increment="50"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="录制控制">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="提示与录制时长" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="这里控制预警提示，以及录像何时自动停止。"
                                               Style="{StaticResource SectionHintStyle}"/>
                                    <Border Height="1" Background="{DynamicResource BorderLight}" Margin="0,12,0,12"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="启用声音提示" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="超时或关键事件发生时播放提醒音。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1"
                                                  IsChecked="{Binding Config.EnableSoundPrompt}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="超时预警提前 / 秒" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="在超时前提前提醒，给操作员留出处理时间。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="1"
                                                           Height="32"
                                                           Value="{Binding Config.TimeoutWarningSeconds}"
                                                           Minimum="3"
                                                           Maximum="120"
                                                           Increment="1"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="启用静止自动停录" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="画面长时间无变化时自动结束录像，减少无效视频。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="AutoStopCheckBox"
                                                  Grid.Column="1"
                                                  IsChecked="{Binding Config.EnableAutoStop}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}"
 Margin="0,0,0,8"
                                          IsEnabled="{Binding IsChecked, ElementName=AutoStopCheckBox, TargetNullValue=False}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="静止超时 / 分钟" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="超过该时长未检测到动作时，自动结束当前录像。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="1"
                                                           Height="32"
                                                           Value="{Binding Config.AutoStopMinutes}"
                                                           Minimum="0.1"
                                                           Maximum="60.0"
                                                           Increment="0.5"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="限制录像时长" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="为单段录像设置上限，避免长时间连续录制。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="MaxDurationCheckBox"
                                                  Grid.Column="1"
                                                  IsChecked="{Binding Config.EnableMaxDuration}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}"
                                          Margin="0,0,0,0"
                                          IsEnabled="{Binding IsChecked, ElementName=MaxDurationCheckBox, TargetNullValue=False}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="最大时长 / 分钟" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="单段录像达到该时长后自动停止。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="1"
                                                           Height="32"
                                                           Value="{Binding Config.MaxDurationMinutes}"
                                                           Minimum="0.1"
                                                           Maximum="60.0"
                                                           Increment="0.5"/>
                                    </Grid>

                                    <Border Height="1" Background="{DynamicResource BorderLight}" Margin="0,12,0,12"/>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="最短录制时长 / 秒" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="录制时长不足此值时自动丢弃不保存，设为 0 则全部保留。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="1"
                                                           Height="32"
                                                           Value="{Binding Config.MinRecordingSeconds}"
                                                           Minimum="0"
                                                           Maximum="30"
                                                           Increment="1"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
        <!-- TAB 4: 存储管理 -->
        <TabItem Header="存储管理">
            <ScrollViewer Padding="40,35">
                <StackPanel>
                    <!-- 第一部分：磁盘矩阵 -->
                    <TextBlock Text="磁盘阵列配置" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Text="* 系统按优先级(Priority)从小到大写入。若全部满，自动清理全局最旧录像。" 
                            FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,12"/>

                    <Border BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource ControlBackground}">
                        <DataGrid x:Name="StorageDataGrid"
                                ItemsSource="{Binding Config.StorageLocations}"
                                AutoGenerateColumns="False" 
                                CanUserAddRows="False"
                                HeadersVisibility="Column"
                                GridLinesVisibility="Horizontal"
                                HorizontalGridLinesBrush="{DynamicResource BorderLight}"
                                BorderThickness="0"
                                Background="Transparent"
                                RowHeight="50"
                                FontSize="13"
                                SelectionMode="Single"
                                CanUserSortColumns="False">
                            <!-- 表头样式：统一风格 -->
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <!-- 行样式：去掉选中时的深蓝色，改为浅色高亮 -->
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ControlBackgroundHover}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            
                            <DataGrid.Columns>
                                <!-- 路径展示 -->
                                <DataGridTemplateColumn Header="存储路径" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Path}" VerticalAlignment="Center" Margin="12,0" 
                                                    TextTrimming="CharacterEllipsis" ToolTip="{Binding Path}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 配额调节 -->
                                <DataGridTemplateColumn Header="配额 (GB)" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <xctk:DoubleUpDown Value="{Binding QuotaGB, UpdateSourceTrigger=PropertyChanged}" 
                                                            Minimum="1" Maximum="10000" Margin="5"
                                                            VerticalAlignment="Center" Height="28"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 优先级调节 -->
                                <DataGridTemplateColumn Header="优先级" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <xctk:IntegerUpDown Value="{Binding Priority, UpdateSourceTrigger=PropertyChanged}" 
                                                                Minimum="0" Maximum="99" Margin="5"
                                                                VerticalAlignment="Center" Height="28"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- 操作按钮：与设置界面其他按钮对齐 -->
                    <StackPanel Orientation="Horizontal" Margin="0,15,0,30">
                        <Button Content="➕ 添加磁盘" Click="BtnAddStorage_Click" 
                                Style="{StaticResource SecondaryActionButtonStyle}" Width="120" Margin="0,0,12,0"/>
                        <Button Content="➖ 移除选中" Click="BtnRemoveStorage_Click" 
                                Style="{StaticResource SecondaryActionButtonStyle}" Width="120"/>
                    </StackPanel>

                    <Border Style="{StaticResource SettingRow}">
                        <Grid>
                            <TextBlock Text="回放列表显示已覆盖记录" VerticalAlignment="Center"/>
                            <CheckBox IsChecked="{Binding Config.ShowDeletedVideos}" 
                                    Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

            <TabItem Header="高级设置">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="识别与启动" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="这些选项决定单号识别规则，以及程序是否随系统启动。"
                                               Style="{StaticResource SectionHintStyle}"/>
                                    <Border Height="1" Background="{DynamicResource BorderLight}" Margin="0,12,0,12"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="单号正则式" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="用于提取单号。仅在你已明确编码规则时再修改。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <TextBox Grid.Column="1" Text="{Binding Config.OrderIdRegex}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="开机自启动" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="开启后会写入当前用户启动项，适合长期驻场设备。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="AutoStartCheckBox"
                                                  Grid.Column="1"
                                                  IsChecked="{Binding Config.AutoStartOnBoot}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="条码冷却时间 (秒)" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="扫描指令条码后隐藏的秒数，防止重复扫描。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="1"
                                                           Height="32"
                                                           Value="{Binding Config.BarcodeCooldownSeconds}"
                                                           Minimum="0.5"
                                                           Maximum="10.0"
                                                           Increment="0.5"/>
                                    </Grid>

                                    <Border Height="1" Background="{DynamicResource BorderLight}" Margin="0,12,0,12"/>
                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="重置编码器检测" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="清除已保存的检测结果，重新分析可用 GPU 编码器。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="立即重新检测" 
                                                Command="{Binding MainVM.ResetEncoderDetectCommand}"
                                                Style="{StaticResource SecondaryActionButtonStyle}"
                                                Height="32" Padding="12,0" HorizontalAlignment="Left" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
        </TabControl>

        <UniformGrid Grid.Row="2" Rows="1" Columns="2" HorizontalAlignment="Right" Width="220">
            <Button Content="取消" Margin="0,0,10,0" Click="BtnCancel_Click" Style="{StaticResource SecondaryActionButtonStyle}">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="保存应用" Click="BtnSave_Click" Style="{StaticResource PrimaryActionButtonStyle}">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </UniformGrid>
    </Grid>
</Window>




