                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsChecked, ElementName=SoundPromptCheckBox}" Value="True"/>
                                                    <Condition Binding="{Binding SelectedValue, ElementName=VoiceEngineComboBox}" Value="Edge"/>
