                                                           Style="{StaticResource SliderValueTextStyle}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="更稳妥" Style="{StaticResource SliderEndLabelStyle}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="BarcodeCooldownSlider"
                                                    Style="{StaticResource SettingsSliderStyle}"
                                                    Minimum="0.5"
                                                    Maximum="10"
                                                    TickFrequency="0.5"
                                                    Value="{Binding Config.BarcodeCooldownSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <Grid Style="{StaticResource SettingRowLastStyle}"
                                          ToolTip="清除已保存的显卡编码检测结果，下次重新判断可用编码器。">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="重置编码器检测" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="录像编码异常时，用它重新检测电脑能力"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="立即重新检测"
                                                Command="{Binding MainVM.ResetEncoderDetectCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                HorizontalAlignment="Left" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="关于">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="72"
                                                Height="72"
                                                CornerRadius="14"
                                                Background="{DynamicResource ControlBackground}"
                                                BorderBrush="{DynamicResource BorderLight}"
                                                BorderThickness="1">
                                            <Image Source="{Binding AppIconImage}"
                                                   Width="56"
                                                   Height="56"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="快递打包监控"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock Text="{Binding AppVersion, StringFormat=版本 {0}}"
                                                       Margin="0,5,0,0"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondary}"/>
                                            <TextBlock Text="面向电商打包场景的录像、回放和订单备注播报工具。"
                                                       Margin="0,6,0,0"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="项目仓库" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="打开 GitHub 仓库，查看源码、发布记录和问题反馈"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <WrapPanel Grid.Column="2">
                                            <Button x:Name="CheckUpdateButton"
                                                    Content="检查更新"
                                                    Click="CheckUpdate_Click"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Margin="0,0,8,8"/>
                                            <Button Content="打开仓库"
                                                    Click="OpenRepository_Click"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Margin="0,0,8,8"/>
                                        </WrapPanel>
                                    </Grid>

                                    <Border Background="{DynamicResource ControlBackground}"
                                            BorderBrush="{DynamicResource BorderDefault}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="12">
                                        <TextBlock TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="12"
                                                   LineHeight="19">
                                            <Run Text="本项目使用 AGPL-3.0 License 开源。"/>
                                            <LineBreak/>
                                            <LineBreak/>
                                            <Run Text="个人学习、自家店铺自用可以免费使用。"/>
                                            <LineBreak/>
                                            <Run Text="修改后对外分发或提供网络服务时，需要遵守 AGPL-3.0 的开源义务。"/>
                                            <LineBreak/>
                                            <Run Text="二次修改分发时请保留原作者署名、版权声明和许可证信息。"/>
                                            <LineBreak/>
                                            <Run Text="使用前请自行确认你的使用方式是否满足 AGPL-3.0 要求。"/>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
        </TabControl>

        <Border Grid.Row="1"
                BorderBrush="{DynamicResource BorderLight}"
                BorderThickness="1,1,0,0"
                Padding="0,14,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="存储空间"
                           Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,12,0"/>
                <ProgressBar Grid.Column="1"
                             Height="8"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding CurrentDiskUsagePercent}"
                             Foreground="{DynamicResource AccentBlue}"
                             Background="{DynamicResource BorderStrong}"
                             BorderThickness="0"
                             VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding CurrentDiskUsageText}"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>

                <UniformGrid Grid.Column="3" Rows="1" Columns="2" Width="220">
                    <Button Content="取消" Margin="0,0,10,0" Click="BtnCancel_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                    <Button Content="保存应用" Click="BtnSave_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                </UniformGrid>
            </Grid>
        </Border>
    </Grid>
</Window>




