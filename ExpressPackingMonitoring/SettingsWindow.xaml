<Window x:Class="ExpressPackingMonitoring.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="设置" Height="680" Width="640"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}" FontFamily="Microsoft YaHei UI, Segoe UI">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <Style TargetType="{x:Type xctk:IntegerUpDown}" BasedOn="{StaticResource {x:Type xctk:IntegerUpDown}}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
        </Style>

        <Style TargetType="{x:Type xctk:DoubleUpDown}" BasedOn="{StaticResource {x:Type xctk:DoubleUpDown}}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource AccentBlueDark}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,0"/>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,0"/>
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <Style x:Key="SectionHintStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <Style x:Key="FieldHintStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="16"/>
        </Style>

        <Style x:Key="SettingRowStyle" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.58"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="MainGrid" Width="44" Height="24" VerticalAlignment="Center">
                            <Border x:Name="BorderUnchecked" CornerRadius="12" Background="{DynamicResource BorderStrong}"/>
                            <Border x:Name="BorderChecked" CornerRadius="12" Background="{DynamicResource AccentBlue}" Opacity="0"/>
                            <Ellipse x:Name="Knob" Width="20" Height="20" Fill="White" HorizontalAlignment="Left" Margin="2,0,0,0">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform X="0"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2" Direction="270"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Knob"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="20" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="BorderChecked"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Knob"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="BorderChecked"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="MainGrid"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.8" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="MainGrid"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18"
                Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="存储空间使用率" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,0"/>
                <ProgressBar Grid.Column="1"
                             Height="8"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding CurrentDiskUsagePercent}"
                             Foreground="{DynamicResource AccentBlue}"
                             Background="{DynamicResource BorderStrong}"
                             BorderThickness="0"
                             VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding CurrentDiskUsageText}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0,0,0,12">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="12,8"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0,0,0,3"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Background="{TemplateBinding Background}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        BorderBrush="{TemplateBinding BorderBrush}">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlueDark}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueDark}"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                            <Condition Property="IsSelected" Value="False"/>
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                        <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <TabItem Header="设备与画面">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="采集设备" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="这些选项决定录像来源和整体清晰度，建议优先确认。"
                                               Style="{StaticResource SectionHintStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="外观主题" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="可跟随系统，或固定为浅色 / 深色主题。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ThemeComboBox"
                                                  Grid.Column="1"
                                                  SelectedValue="{Binding Config.Theme}"
                                                  SelectedValuePath="Content"
                                                  Cursor="Hand"
                                                  SelectionChanged="ThemeComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Auto"/>
                                            <ComboBoxItem Content="Light"/>
                                            <ComboBoxItem Content="Dark"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="摄像头" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="选择当前用于录制的采集设备。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="CameraComboBox"
                                                  Grid.Column="1"
                                                  SelectedValuePath="Index"
                                                  DisplayMemberPath="Name"
                                                  SelectedValue="{Binding Config.CameraIndex}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="录像质量" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="清晰度越高，占用空间越大；帧率越高，画面越流畅。"
                                               Style="{StaticResource SectionHintStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="分辨率" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="常规记录建议使用 1080P；空间紧张时可降为 720P。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ResComboBox"
                                                  Grid.Column="1"
                                                  DisplayMemberPath="Name"
                                                  Cursor="Hand"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="录制帧率 / FPS" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="包装台场景通常 15 到 25 FPS 即可满足回溯。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:IntegerUpDown Grid.Column="1"
                                                            Height="32"
                                                            Value="{Binding Config.Fps}"
                                                            Minimum="5"
                                                            Maximum="60"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="特写策略">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="启用智能特写" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="当系统识别到需要关注的画面时，自动放大关键区域。"
                                               Style="{StaticResource SectionHintStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,18,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="智能特写开关" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="关闭后，下方特写参数不会参与录制逻辑。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="SmartZoomCheckBox"
                                                  Grid.Column="1"
                                                  IsChecked="{Binding Config.EnableSmartZoom}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}"
                                    IsEnabled="{Binding IsChecked, ElementName=SmartZoomCheckBox, TargetNullValue=False}">
                                <StackPanel>
                                    <TextBlock Text="特写参数" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="这些参数控制特写触发节奏和持续时间。"
                                               Style="{StaticResource SectionHintStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="特写放大倍数" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="倍率越高，细节越清楚，但可见范围越小。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ZoomScaleComboBox"
                                                  Grid.Column="1"
                                                  SelectedItem="{Binding Config.ZoomScale}"
                                                  Cursor="Hand"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="延迟触发 / 秒" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="用于过滤短暂抖动，避免频繁进入特写。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="1"
                                                           Height="32"
                                                           Value="{Binding Config.ZoomDelaySeconds}"
                                                           Minimum="0"
                                                           Increment="0.5"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="特写保持时间 / 秒" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="设置一次特写保持多久后再恢复常规视角。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="1"
                                                           Height="32"
                                                           Value="{Binding Config.ZoomDurationSeconds}"
                                                           Minimum="0"
                                                           Increment="0.5"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="录制控制">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="提示与录制时长" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="这里控制预警提示，以及录像何时自动停止。"
                                               Style="{StaticResource SectionHintStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="启用声音提示" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="超时或关键事件发生时播放提醒音。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1"
                                                  IsChecked="{Binding Config.EnableSoundPrompt}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="超时预警提前 / 秒" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="在超时前提前提醒，给操作员留出处理时间。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="1"
                                                           Height="32"
                                                           Value="{Binding Config.TimeoutWarningSeconds}"
                                                           Minimum="3"
                                                           Maximum="120"
                                                           Increment="1"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="启用静止自动停录" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="画面长时间无变化时自动结束录像，减少无效视频。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="AutoStopCheckBox"
                                                  Grid.Column="1"
                                                  IsChecked="{Binding Config.EnableAutoStop}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}"
 Margin="0,0,0,8"
                                          IsEnabled="{Binding IsChecked, ElementName=AutoStopCheckBox, TargetNullValue=False}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="静止超时 / 分钟" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="超过该时长未检测到动作时，自动结束当前录像。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="1"
                                                           Height="32"
                                                           Value="{Binding Config.AutoStopMinutes}"
                                                           Minimum="0.1"
                                                           Maximum="60.0"
                                                           Increment="0.5"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="限制录像时长" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="为单段录像设置上限，避免长时间连续录制。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="MaxDurationCheckBox"
                                                  Grid.Column="1"
                                                  IsChecked="{Binding Config.EnableMaxDuration}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}"
                                          Margin="0,0,0,0"
                                          IsEnabled="{Binding IsChecked, ElementName=MaxDurationCheckBox, TargetNullValue=False}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="最大时长 / 分钟" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="单段录像达到该时长后自动停止。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="1"
                                                           Height="32"
                                                           Value="{Binding Config.MaxDurationMinutes}"
                                                           Minimum="0.1"
                                                           Maximum="60.0"
                                                           Increment="0.5"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="存储空间">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="存储与检索" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="建议将路径设置到本地磁盘，并结合磁盘配额控制历史视频总量。"
                                               Style="{StaticResource SectionHintStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="视频存储路径" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="录像文件保存位置，优先选择稳定的本地目录。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <Grid Grid.Column="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="PathTextBox"
                                                     Text="{Binding Config.VideoStoragePath}"
                                                     IsReadOnly="True"
                                                     Background="{DynamicResource BorderLight}"
                                                     Foreground="{DynamicResource TextSecondary}"/>
                                            <Button Grid.Column="1"
                                                    Content="浏览"
                                                    Width="68"
                                                    Margin="8,0,0,0"
                                                    Click="BtnBrowsePath_Click"
                                                    Style="{StaticResource SecondaryActionButtonStyle}">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="6"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </Grid>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="磁盘配额 / GB" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="达到上限后，系统可按策略回收旧视频，避免磁盘写满。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <xctk:DoubleUpDown Grid.Column="1"
                                                           Height="32"
                                                           Value="{Binding Config.MaxDiskSpaceGB}"
                                                           Minimum="0.5"
                                                           Maximum="5000.0"
                                                           Increment="0.5"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="显示已删除视频" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="在列表中保留已删除记录，便于对账和追溯。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1"
                                                  IsChecked="{Binding Config.ShowDeletedVideos}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="高级设置">
                <Border Background="Transparent" Padding="0,4,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="识别与启动" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="这些选项决定单号识别规则，以及程序是否随系统启动。"
                                               Style="{StaticResource SectionHintStyle}"/>

                                    <Grid Style="{StaticResource SettingRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="单号正则式" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="用于提取单号。仅在你已明确编码规则时再修改。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <TextBox Grid.Column="1" Text="{Binding Config.OrderIdRegex}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource SettingRowStyle}" Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="开机自启动" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="开启后会写入当前用户启动项，适合长期驻场设备。"
                                                       Style="{StaticResource FieldHintStyle}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="AutoStartCheckBox"
                                                  Grid.Column="1"
                                                  IsChecked="{Binding Config.AutoStartOnBoot}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
        </TabControl>

        <UniformGrid Grid.Row="2" Rows="1" Columns="2" HorizontalAlignment="Right" Width="220">
            <Button Content="取消" Margin="0,0,10,0" Click="BtnCancel_Click" Style="{StaticResource SecondaryActionButtonStyle}">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="保存应用" Click="BtnSave_Click" Style="{StaticResource PrimaryActionButtonStyle}">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </UniformGrid>
    </Grid>
</Window>




