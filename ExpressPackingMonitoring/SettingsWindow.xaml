<Window x:Class="ExpressPackingMonitoring.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="系统参数设置" Height="580" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource ControlBackground}" FontFamily="Microsoft YaHei UI, Segoe UI">
    
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="6" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="MainGrid" Width="44" Height="24" VerticalAlignment="Center">
                            <Border x:Name="BorderUnchecked" CornerRadius="12" Background="{DynamicResource BorderStrong}"/>
                            <Border x:Name="BorderChecked" CornerRadius="12" Background="{DynamicResource AccentBlue}" Opacity="0"/>
                            <Ellipse x:Name="Knob" Width="20" Height="20" Fill="White" HorizontalAlignment="Left" Margin="2,0,0,0">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform X="0"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2" Direction="270"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Knob" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="20" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="BorderChecked" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Knob" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="BorderChecked" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="MainGrid" Storyboard.TargetProperty="Opacity" To="0.8" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="MainGrid" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource BorderLight}" CornerRadius="6" Padding="16,12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="磁盘占用" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" Margin="12,0" Height="8" Minimum="0" Maximum="100" Value="{Binding CurrentDiskUsagePercent}" Foreground="{DynamicResource AccentBlue}" Background="{DynamicResource BorderStrong}" BorderThickness="0"/>

                <TextBlock Grid.Column="2" Text="{Binding CurrentDiskUsageText}" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

                <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0,0,0,16">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="15"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="16,10"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0,0,0,3"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}">
                                    <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlueDark}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueDark}"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                            <Condition Property="IsSelected" Value="False"/>
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                        <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <TabItem Header=" 设备">
                <Border Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="{DynamicResource ShadowColor}"/>
                    </Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="-10" Padding="10">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="外观主题" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <ComboBox x:Name="ThemeComboBox" Grid.Column="1" SelectedValue="{Binding Config.Theme}" SelectedValuePath="Content"  Cursor="Hand" SelectionChanged="ThemeComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Auto" />
                                    <ComboBoxItem Content="Light" />
                                    <ComboBoxItem Content="Dark" />
                                </ComboBox>
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="摄像头" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <ComboBox x:Name="CameraComboBox" Grid.Column="1" SelectedValuePath="Index" DisplayMemberPath="Name" SelectedValue="{Binding Config.CameraIndex}" />
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="分辨率" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <ComboBox x:Name="ResComboBox" Grid.Column="1" DisplayMemberPath="Name"  Cursor="Hand"/>
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="录制帧率/FPS" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <xctk:IntegerUpDown Grid.Column="1" Value="{Binding Config.Fps}" Minimum="5" Maximum="60" />
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header=" 特写">
                <Border Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05"/>
                    </Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="-10" Padding="10">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="启用智能特写" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding Config.EnableSmartZoom}" VerticalAlignment="Center" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Left"/>
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="特写放大倍数" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <ComboBox x:Name="ZoomScaleComboBox" Grid.Column="1" SelectedItem="{Binding Config.ZoomScale}"  Cursor="Hand"/>
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="延迟触发/秒" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <xctk:DoubleUpDown Grid.Column="1" Value="{Binding Config.ZoomDelaySeconds}" Minimum="0" Increment="0.5" />
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="特写保持时间/秒" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <xctk:DoubleUpDown Grid.Column="1" Value="{Binding Config.ZoomDurationSeconds}" Minimum="0" Increment="0.5" />
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header=" 高级">
                <Border Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05"/>
                    </Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="-10" Padding="10">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="启用声音提示" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding Config.EnableSoundPrompt}" VerticalAlignment="Center" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Left"/>
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="超时预警提前/秒" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <xctk:DoubleUpDown Grid.Column="1" Value="{Binding Config.TimeoutWarningSeconds}" Minimum="3" Maximum="120" Increment="1" />
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="视频存储路径" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <TextBox x:Name="PathTextBox" Grid.Column="1" Text="{Binding Config.VideoStoragePath}"  IsReadOnly="True" Background="{DynamicResource BorderLight}" Foreground="{DynamicResource TextSecondary}"/>
                                <Button Grid.Column="2" Content="浏览" Width="60" Margin="8,0,0,0" Click="BtnBrowsePath_Click" Background="{DynamicResource BorderDefault}" BorderThickness="0" Cursor="Hand" FontWeight="Bold">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="4"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="启用静止自动停录" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding Config.EnableAutoStop}" VerticalAlignment="Center" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Left"/>
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="静止超时/分钟" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <xctk:DoubleUpDown Grid.Column="1" Value="{Binding Config.AutoStopMinutes}" Minimum="0.1" Maximum="60.0" Increment="0.5" />
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="限制录像时长" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding Config.EnableMaxDuration}" VerticalAlignment="Center" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Left"/>
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="最大时长/分钟" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <xctk:DoubleUpDown Grid.Column="1" Value="{Binding Config.MaxDurationMinutes}" Minimum="0.1" Maximum="60.0" Increment="0.5" />
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="单号正则式" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <TextBox Grid.Column="1" Text="{Binding Config.OrderIdRegex}" />
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="磁盘配额/GB" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <xctk:DoubleUpDown Grid.Column="1" Value="{Binding Config.MaxDiskSpaceGB}" Minimum="0.5" Maximum="5000.0" Increment="0.5" />
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="显示已删除视频" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding Config.ShowDeletedVideos}" VerticalAlignment="Center" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Left"/>
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="开机自启动" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <CheckBox x:Name="AutoStartCheckBox" Grid.Column="1" IsChecked="{Binding Config.AutoStartOnBoot}" VerticalAlignment="Center" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Left"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
        </TabControl>

        <UniformGrid Grid.Row="2" Rows="1" Columns="2" HorizontalAlignment="Right" Width="180">
            <Button Content="取消" Height="38" Margin="0,0,8,0" Click="BtnCancel_Click" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderStrong}" BorderThickness="1" Foreground="{DynamicResource TextSecondary}" FontWeight="SemiBold" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="保存应用" Height="38" Click="BtnSave_Click" Background="{DynamicResource AccentBlueDark}" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </UniformGrid>
    </Grid>
</Window>




