<Window x:Class="ExpressPackingMonitoring.PlaybackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎬 历史录像检索与回放" Height="700" Width="1100"
        WindowStartupLocation="CenterOwner" Background="#F0F2F5"
        Closing="Window_Closing">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,15,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="📅 录像日期范围:" FontWeight="Bold" Margin="0,0,0,5" Foreground="#555"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <DatePicker x:Name="DpStartDate" Grid.Column="0" SelectedDateChanged="DateFilterChanged"/>
                        <TextBlock Grid.Column="1" Text="至" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <DatePicker x:Name="DpEndDate" Grid.Column="2" SelectedDateChanged="DateFilterChanged"/>
                    </Grid>

                    <TextBlock Text="🔍 单号精准搜索:" FontWeight="Bold" Margin="0,0,0,5" Foreground="#555"/>
                    <TextBox x:Name="SearchBox" FontSize="14" Padding="5" TextChanged="TextFilterChanged" BorderBrush="#0078D7" BorderThickness="2"/>
                </StackPanel>

                <ListView x:Name="VideoList" Grid.Row="1" FontSize="14" SelectionChanged="VideoList_SelectionChanged" BorderThickness="1" BorderBrush="#E2E8F0" Background="#F8FAFC">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="8,6">
                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" FontWeight="Medium" Foreground="#334155" TextTrimming="CharacterEllipsis"/>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="Black" CornerRadius="8" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <MediaElement x:Name="MediaPlayer" LoadedBehavior="Manual" UnloadedBehavior="Stop" Stretch="Uniform" MediaOpened="MediaPlayer_MediaOpened"/>

                <Border VerticalAlignment="Bottom" Background="#D8000000" Padding="15,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="BtnTogglePlay" Grid.Column="0" Content="▶" Width="40" Height="30" Click="BtnTogglePlay_Click" Background="#28A745" Foreground="White" FontWeight="Bold" ToolTip="播放/暂停" Margin="0,0,15,0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Slider x:Name="TimelineSlider" Grid.Column="1" VerticalAlignment="Center" Minimum="0" 
                                Thumb.DragStarted="TimelineSlider_DragStarted" 
                                Thumb.DragCompleted="TimelineSlider_DragCompleted" 
                                ValueChanged="TimelineSlider_ValueChanged"/>

                        <TextBlock x:Name="TimeLabel" Grid.Column="2" Text="00:00:00 / 00:00:00" Foreground="White" VerticalAlignment="Center" Margin="15,0,0,0" FontFamily="Consolas"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>