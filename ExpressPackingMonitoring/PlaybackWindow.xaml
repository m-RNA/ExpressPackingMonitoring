<Window x:Class="ExpressPackingMonitoring.PlaybackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📦 历史录像检索与回放" Height="700" Width="1100"
        WindowStartupLocation="CenterOwner" Background="#F0F2F5">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,15,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="📅 录像日期范围:" FontWeight="Bold" Margin="0,0,0,5" Foreground="#555"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <DatePicker x:Name="DpStartDate" Grid.Column="0" SelectedDateChanged="FilterChanged"/>
                        <TextBlock Grid.Column="1" Text="至" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <DatePicker x:Name="DpEndDate" Grid.Column="2" SelectedDateChanged="FilterChanged"/>
                    </Grid>

                    <TextBlock Text="🚚 快递公司:" FontWeight="Bold" Margin="0,0,0,5" Foreground="#555"/>
                    <ComboBox x:Name="ExpressComboBox" Margin="0,0,0,10" SelectionChanged="FilterChanged">
                        <ComboBoxItem Content="全部快递" IsSelected="True"/>
                        <ComboBoxItem Content="顺丰 (SF开头)"/>
                        <ComboBoxItem Content="京东 (JD开头)"/>
                        <ComboBoxItem Content="邮政/EMS (EX/EM开头)"/>
                        <ComboBoxItem Content="圆通 (YT开头)"/>
                        <ComboBoxItem Content="中通 (ZT开头)"/>
                        <ComboBoxItem Content="申通 (ST开头)"/>
                        <ComboBoxItem Content="韵达 (YD开头)"/>
                        <ComboBoxItem Content="极兔 (JT开头)"/>
                    </ComboBox>

                    <TextBlock Text="🔍 单号精准搜索:" FontWeight="Bold" Margin="0,0,0,5" Foreground="#555"/>
                    <TextBox x:Name="SearchBox" FontSize="14" Padding="5" TextChanged="FilterChanged" BorderBrush="#0078D7" BorderThickness="2"/>
                </StackPanel>

                <ListView x:Name="VideoList" Grid.Row="1" DisplayMemberPath="Name" FontSize="13" 
                         SelectionChanged="VideoList_SelectionChanged" BorderThickness="1" BorderBrush="#DDDDDD" Background="#FAFAFA"/>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="Black" CornerRadius="8" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <MediaElement x:Name="MediaPlayer" LoadedBehavior="Manual" UnloadedBehavior="Stop" Stretch="Uniform" MediaOpened="MediaPlayer_MediaOpened"/>

                <Border VerticalAlignment="Bottom" Background="#D8000000" Padding="15,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,15,0">
                            <Button Content="▶" Width="40" Height="30" Click="BtnPlay_Click" Background="#28A745" Foreground="White" FontWeight="Bold" ToolTip="播放"/>
                            <Button Content="⏸" Width="40" Height="30" Margin="5,0,0,0" Click="BtnPause_Click" Background="#FFC107" Foreground="Black" FontWeight="Bold" ToolTip="暂停"/>
                        </StackPanel>

                        <Slider x:Name="TimelineSlider" Grid.Column="1" VerticalAlignment="Center" Minimum="0" 
                                Thumb.DragStarted="TimelineSlider_DragStarted" 
                                Thumb.DragCompleted="TimelineSlider_DragCompleted" 
                                ValueChanged="TimelineSlider_ValueChanged"/>

                        <TextBlock x:Name="TimeLabel" Grid.Column="2" Text="00:00:00 / 00:00:00" Foreground="White" VerticalAlignment="Center" Margin="15,0,0,0" FontFamily="Consolas"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>