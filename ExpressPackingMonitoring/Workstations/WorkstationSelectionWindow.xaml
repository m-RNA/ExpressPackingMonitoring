<Window x:Class="ExpressPackingMonitoring.WorkstationSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择录像方式" Height="420" Width="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="/app.ico"
        Background="{DynamicResource WindowBackground}"
        FontFamily="Microsoft YaHei UI, Segoe UI">
    <Window.Resources>
        <Style x:Key="WorkstationButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BorderLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="34">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,26">
            <TextBlock Text="请选择录像方式"
                       FontSize="28"
                       FontWeight="Black"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="请选择是否使用这台电脑的摄像头录像，两种方式都支持手机录像备份和网页回放"
                       Margin="0,8,0,0"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondary}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Style="{StaticResource WorkstationButtonStyle}" Click="CameraMonitor_Click">
                <StackPanel>
                    <Path Data="{StaticResource FluentVideoIcon}"
                          Width="56"
                          Height="56"
                          Stretch="Uniform"
                          Fill="{DynamicResource AccentBlue}"
                          HorizontalAlignment="Left"/>
                    <TextBlock Text="使用电脑摄像头录像"
                               Margin="0,20,0,0"
                               FontSize="23"
                               FontWeight="Black"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="使用这台电脑的摄像头扫码并录像，同时支持手机录像备份和局域网回放"
                               Margin="0,10,0,0"
                               FontSize="14"
                               LineHeight="22"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="2" Style="{StaticResource WorkstationButtonStyle}" Click="PrintStation_Click">
                <StackPanel>
                    <Path Data="{StaticResource FluentStorageIcon}"
                          Width="56"
                          Height="56"
                          Stretch="Uniform"
                          Fill="{DynamicResource AccentOrange}"
                          HorizontalAlignment="Left"/>
                    <TextBlock Text="我没有电脑摄像头"
                               Margin="0,20,0,0"
                               FontSize="23"
                               FontWeight="Black"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="不使用电脑摄像头，只接收并备份手机录像，支持本机和局域网回放"
                               Margin="0,10,0,0"
                               FontSize="14"
                               LineHeight="22"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
