<Window x:Class="ExpressPackingMonitoring.PrintWorkstationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="手机录像备份"
        Width="820"
        Height="690"
        MinWidth="720"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="22"/>
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Margin" Value="0,0,10,8"/>
            <Setter Property="Padding" Value="16,8"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="手机录像备份"
                               FontSize="28"
                               FontWeight="Black"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Margin="0,7,0,0"
                               Text="这台电脑不使用摄像头，只接收并备份手机录像，支持本机和局域网回放"
                               FontSize="14"
                               Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
                <Button Grid.Column="1"
                        VerticalAlignment="Center"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="SwitchWorkstation_Click"
                        Content="更改录像方式"/>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="48" Height="48" CornerRadius="15"
                            Background="{DynamicResource ControlBackground}">
                        <Path x:Name="StatusIconPath"
                              Data="{StaticResource FluentHourglassIcon}"
                              Width="24" Height="24" Stretch="Uniform"
                              Fill="{DynamicResource AccentBlue}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="StatusTextBlock"
                                   Text="正在启动手机录像备份服务"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock x:Name="StatusHintTextBlock"
                                   Margin="0,5,0,0"
                                   Text="正在打开录像数据库和本机回放服务"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondary}"/>
                        <WrapPanel Margin="0,18,0,0">
                            <Button x:Name="ConnectPhoneButton"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="ConnectPhone_Click"
                                    Content="连接手机"/>
                            <Button x:Name="OpenWebButton"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="OpenWeb_Click"
                                    Content="网页回放"/>
                            <Button x:Name="StatisticsButton"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="OpenStatistics_Click"
                                    Content="数据统计"/>
                            <Button x:Name="PlaybackButton"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="OpenPlayback_Click"
                                    Content="录像回放"/>
                            <Button x:Name="SettingsButton"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="OpenSettings_Click"
                                    Content="设置"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="局域网回放"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock x:Name="LanAddressTextBlock"
                               Margin="0,7,0,0"
                               Text="服务启动后显示局域网地址"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <WrapPanel Margin="0,16,0,0">
                        <Button x:Name="CopyLanAddressButton"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="CopyLanAddress_Click"
                                Content="复制局域网地址"/>
                        <Button x:Name="RepairLanButton"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="RepairLan_Click"
                                Content="修复局域网"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="6" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="订单工具"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Margin="0,7,0,0"
                               Text="订单备注直接发送到本机，并写入录像数据库供手机录像关联"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <WrapPanel Margin="0,16,0,0">
                        <Button Style="{StaticResource ActionButtonStyle}"
                                Click="InstallTool_Click"
                                Content="安装订单备注插件"/>
                        <Button Style="{StaticResource ActionButtonStyle}"
                                Click="TestReceive_Click"
                                Content="测试接收"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
