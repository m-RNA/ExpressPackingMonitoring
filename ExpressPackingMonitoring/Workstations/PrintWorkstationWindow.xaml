<Window x:Class="ExpressPackingMonitoring.PrintWorkstationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="快递单打印工位"
        Height="500"
        Width="750"
        MinHeight="500"
        MinWidth="750"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Icon="/app.ico"
        Background="{DynamicResource WindowBackground}"
        FontFamily="Microsoft YaHei UI, Segoe UI">

    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="18"
                          ShadowDepth="2"
                          Opacity="0.10"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="116"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="126"/>
            <Setter Property="Margin" Value="8,0,0,8"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="LineHeight" Value="20"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    CornerRadius="14"
                    Padding="18"
                    Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="1"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="52"
                            Height="52"
                            CornerRadius="14"
                            Background="{DynamicResource ControlBackground}">
                        <Path Data="{StaticResource FluentPrinterIcon}"
                              Width="28"
                              Height="28"
                              Stretch="Uniform"
                              Fill="{DynamicResource AccentOrange}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center">
                        <TextBlock Text="快递单打印工位"
                                   FontSize="26"
                                   FontWeight="Black"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="将快递助手订单发送到摄像头监控工位，用于包装现场语音提醒与录像关联。"
                                   Margin="0,7,0,0"
                                   FontSize="13"
                                   LineHeight="20"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondary}"/>
                    </StackPanel>

                    <Button Grid.Column="3"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="108"
                            Height="34"
                            Padding="12,0"
                            VerticalAlignment="Top"
                            Click="SwitchWorkstation_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource FluentArrowSyncIcon}"
                                  Width="15"
                                  Height="15"
                                  Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Margin="0,0,6,0"/>
                            <TextBlock Text="切换工位"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Address Card -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="摄像头监控工位地址"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="填写或自动查找到监控端地址后，订单信息会发送到对应工位。"
                                       Margin="0,5,0,0"
                                       Style="{StaticResource HintTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top">
                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    MinWidth="110"
                                    Margin="0,0,10,0"
                                    Click="FindMonitor_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource FluentSearchIcon}"
                                          Width="16"
                                          Height="16"
                                          Stretch="Uniform"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Margin="0,0,7,0"/>
                                    <TextBlock Text="自动查找"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    MinWidth="96"
                                    Click="Reconnect_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource FluentLinkIcon}"
                                          Width="16"
                                          Height="16"
                                          Stretch="Uniform"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Margin="0,0,7,0"/>
                                    <TextBlock Text="连接"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2"
                            Height="44"
                            CornerRadius="10"
                            Background="{DynamicResource ControlBackground}"
                            BorderBrush="{DynamicResource BorderStrong}"
                            BorderThickness="1">
                        <TextBox x:Name="AddressTextBox"
                                 Padding="13,0"
                                 VerticalContentAlignment="Center"
                                 FontSize="15"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextPrimary}"
                                 BorderThickness="0"
                                 CaretBrush="{DynamicResource AccentBlue}"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Status and Actions -->
            <Border Grid.Row="4" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="42"
                            Height="42"
                            CornerRadius="13"
                            Background="{DynamicResource ControlBackground}"
                            VerticalAlignment="Top">
                        <Path Data="{StaticResource FluentCheckIcon}"
                              Width="22"
                              Height="22"
                              Stretch="Uniform"
                              Fill="{DynamicResource AccentBlue}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                        <TextBlock x:Name="StatusTextBlock"
                                   Text="正在检查上次连接..."
                                   FontSize="20"
                                   FontWeight="Black"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock x:Name="StatusHintTextBlock"
                                   Margin="0,6,12,0"
                                   Text="如果这台电脑第一次使用，请先自动查找摄像头监控工位。"
                                   Style="{StaticResource HintTextStyle}"/>
                    </StackPanel>

                    <WrapPanel Grid.Column="3"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Right">
                        <Button Style="{StaticResource ActionButtonStyle}"
                                MinWidth="132"
                                Click="InstallTool_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource FluentPrinterIcon}"
                                      Width="17"
                                      Height="17"
                                      Stretch="Uniform"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Margin="0,0,8,0"/>
                                <TextBlock Text="安装联动工具"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ActionButtonStyle}"
                                MinWidth="116"
                                Click="TestSend_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource FluentCheckIcon}"
                                      Width="17"
                                      Height="17"
                                      Stretch="Uniform"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Margin="0,0,8,0"/>
                                <TextBlock Text="测试发送"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- Footer Hint -->
            <Border Grid.Row="6"
                    CornerRadius="12"
                    Padding="14,11"
                    Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Path Grid.Column="0"
                          Data="{StaticResource FluentVideoIcon}"
                          Width="16"
                          Height="16"
                          Stretch="Uniform"
                          Fill="{DynamicResource TextSecondary}"
                          VerticalAlignment="Top"
                          Margin="0,1,0,0"/>

                    <TextBlock Grid.Column="2"
                               Text="提示：没有安装本程序的普通电脑，也可以直接用浏览器打开摄像头监控工位显示的地址查看视频。"
                               FontSize="12"
                               LineHeight="18"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}"/>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
